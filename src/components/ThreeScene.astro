<div id="scene-container" class="w-full h-full relative"></div>

<script>
  import * as THREE from "three";
  import { GLTFLoader } from "three/examples/jsm/loaders/GLTFLoader.js";
  import { DRACOLoader } from "three/examples/jsm/loaders/DRACOLoader.js";
  import { OrbitControls } from "three/examples/jsm/controls/OrbitControls.js";
  import {
    CSS2DRenderer,
    CSS2DObject,
  } from "three/examples/jsm/renderers/CSS2DRenderer.js";
  import gsap from "gsap";

  // --- Configuration ---
  const container = document.getElementById("scene-container");

  if (container) {
    // 1. Scene & Camera
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(
      45,
      container.clientWidth / container.clientHeight,
      0.1,
      1000,
    );
    camera.position.set(0, 0, 8.5);

    // 2. Renderers
    // WebGL Renderer (for 3D objects)
    const renderer = new THREE.WebGLRenderer({
      alpha: true,
      antialias: true,
      powerPreference: "high-performance",
    });
    renderer.setSize(container.clientWidth, container.clientHeight);
    renderer.setPixelRatio(window.devicePixelRatio); // Full resolution
    renderer.shadowMap.enabled = true;
    renderer.shadowMap.type = THREE.PCFSoftShadowMap;
    // container.appendChild(renderer.domElement);
    // We append relatively positioned
    renderer.domElement.style.position = "absolute";
    renderer.domElement.style.top = "0";
    renderer.domElement.style.left = "0";
    container.appendChild(renderer.domElement);

    // CSS2D Renderer (for HTML labels/cards)
    const labelRenderer = new CSS2DRenderer();
    labelRenderer.setSize(container.clientWidth, container.clientHeight);
    labelRenderer.domElement.style.position = "absolute";
    labelRenderer.domElement.style.top = "0";
    labelRenderer.domElement.style.left = "0";
    // Important: Allow pointer events on the label renderer's container so OrbitControls works,
    // but the labels themselves might block if not handled.
    // Usually we want OrbitControls to listen to the top-most element.
    // We'll attach OrbitControls to labelRenderer.domElement which is on top.
    labelRenderer.domElement.style.pointerEvents = "auto";
    container.appendChild(labelRenderer.domElement);

    // Controls
    const controls = new OrbitControls(camera, labelRenderer.domElement);
    controls.enableDamping = true;
    controls.dampingFactor = 0.05;
    controls.enableZoom = false; // Disable zoom to keep layout consistent
    controls.minPolarAngle = Math.PI / 2.5; // Limit vertical angle
    controls.maxPolarAngle = Math.PI / 1.5;
    controls.target.set(0, -0.2, 0); // Target the model center

    // 3. Lighting (Studio Setup)
    const ambientLight = new THREE.AmbientLight(0xffffff, 0.4);
    scene.add(ambientLight);

    const mainLight = new THREE.DirectionalLight(0xffffff, 3.5); // Boosted
    mainLight.position.set(5, 5, 5);
    mainLight.castShadow = true;
    scene.add(mainLight);

    const fillLight = new THREE.DirectionalLight(0x9d4edd, 2.5); // Boosted
    fillLight.position.set(-5, 0, 5);
    scene.add(fillLight);

    const rimLight = new THREE.SpotLight(0xffffff, 4.0); // Boosted
    rimLight.position.set(0, 5, -5);
    scene.add(rimLight);

    // Hemisphere Light for overall fill
    const hemiLight = new THREE.HemisphereLight(0xffffff, 0x444444, 2.0);
    scene.add(hemiLight);

    // 4. Avatar (GLB Model)

    const avatarGroup = new THREE.Group();
    scene.add(avatarGroup);

    const loader = new GLTFLoader();
    const dracoLoader = new DRACOLoader();
    dracoLoader.setDecoderPath(
      "https://www.gstatic.com/draco/versioned/decoders/1.5.6/",
    );
    loader.setDRACOLoader(dracoLoader);

    let avatarModel: THREE.Group | null = null; // Store reference for animation

    loader.load(
      "/yeison.glb",
      (gltf) => {
        const model = gltf.scene;
        avatarModel = model;

        model.scale.set(4.5, 4.5, 4.5); // Reduced scale slightly
        model.position.y = -0.2; // Raised further
        model.position.x = 0;

        // El modelo trae una rotación por defecto desde el editor.
        // Rotamos el modelo en el eje Y para que mire hacia al frente
        model.rotation.y = -Math.PI / 2;

        model.traverse((child) => {
          if ((child as THREE.Mesh).isMesh) {
            child.castShadow = true;
            child.receiveShadow = true;

            // Enhance material to avoid darkness
            const mat = (child as THREE.Mesh)
              .material as THREE.MeshStandardMaterial;
            if (mat) {
              mat.envMapIntensity = 3.0; // Boost environment reflections
              // Optional: If still too dark, we can boost emissive slightly
              // mat.emissive = new THREE.Color(0x222222);
            }
          }
        });

        avatarGroup.add(model);
      },
      undefined,
      (error) => {
        console.error("An error happened loading GLB:", error);
      },
    );

    // 5. Tech Cards (CSS2D)
    // We create invisible 3D anchors for the labels to stick to
    interface CardData {
      title: string;
      tech: string;
      icon: string; // URL or svg string
      color: string;
      pos: [number, number, number];
    }

    const cards: CardData[] = [
      {
        title: "Frontend",
        tech: "React.js",
        color: "#61dafb", // React Blue
        pos: [-1.8, 1.5, 0], // Top Left
        icon: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="-11.5 -10.23174 23 20.46348"><circle cx="0" cy="0" r="2.05" fill="#61dafb"/><g stroke="#61dafb" stroke-width="1" fill="none"><ellipse rx="11" ry="4.2"/><ellipse rx="11" ry="4.2" transform="rotate(60)"/><ellipse rx="11" ry="4.2" transform="rotate(120)"/></g></svg>',
      },
      {
        title: "Framework",
        tech: "Next.js",
        color: "#ffffff",
        pos: [1.8, 1.8, -0.8], // Top Right
        icon: '<svg viewBox="0 0 180 180" xmlns="http://www.w3.org/2000/svg"><path d="M90 180c49.706 0 90-40.294 90-90S139.706 0 90 0 0 40.294 0 90s40.294 90 90 90z" fill="#fff"/><path d="M149.508 157.52 69.142 54H54v71.97h12.114V69.384l73.885 95.461c3.334-2.231 6.51-4.68 9.509-7.325z" fill="#000"/><path d="M115.012 54h12.113v71.97h-12.113z" fill="#000"/></svg>',
      },
      {
        title: "Backend",
        tech: "Node.js",
        color: "#339933", // Node Green
        pos: [2.0, -1.0, 0.4], // Bottom Right
        icon: '<svg viewBox="0 0 256 256" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid"><path d="M128 0 8.79 68.42v127.35L128 256l119.21-60.23V68.42L128 0zm-15.89 193.36-16.11 9.4 69.89-40.54V99.51l-69.89 39.52v54.33zM143.6 63.36l15.65-9.15-68.99 39.63v62.42l68.99-40.23V63.36zM61.94 92.76l63.5-36.57v-25.2L42.11 79.94v83.9l19.83-11.2V92.76zm131.95 0v59.88l19.83 11.2V79.94l-83.33-48.91v25.2l63.5 36.53z" fill="#339933"/></svg>',
      },
      {
        title: "DevOps",
        tech: "AWS",
        color: "#FF9900",
        pos: [-1.6, -1.6, 0.4], // Bottom Left
        icon: '<svg xml:space="preserve" viewBox="0 0 304 182" xmlns="http://www.w3.org/2000/svg"><path fill="#ffffff" d="m86 66 2 9c0 3 1 5 3 8v2l-1 3-7 4-2 1-3-1-4-5-3-6c-8 9-18 14-29 14-9 0-16-3-20-8-5-4-8-11-8-19s3-15 9-20c6-6 14-8 25-8a79 79 0 0 1 22 3v-7c0-8-2-13-5-16-3-4-8-5-16-5l-11 1a80 80 0 0 0-14 5h-2c-1 0-2-1-2-3v-5l1-3c0-1 1-2 3-2l12-5 16-2c12 0 20 3 26 8 5 6 8 14 8 25v32zM46 82l10-2c4-1 7-4 10-7l3-6 1-9v-4a84 84 0 0 0-19-2c-6 0-11 1-15 4-3 2-4 6-4 11s1 8 3 11c3 2 6 4 11 4zm80 10-4-1-2-3-23-78-1-4 2-2h10l4 1 2 4 17 66 15-66 2-4 4-1h8l4 1 2 4 16 67 17-67 2-4 4-1h9c2 0 3 1 3 2v2l-1 2-24 78-2 4-4 1h-9l-4-1-1-4-16-65-15 64-2 4-4 1h-9zm129 3a66 66 0 0 1-27-6l-3-3-1-2v-5c0-2 1-3 2-3h2l3 1a54 54 0 0 0 23 5c6 0 11-2 14-4 4-2 5-5 5-9l-2-7-10-5-15-5c-7-2-13-6-16-10a24 24 0 0 1 5-34l10-5a44 44 0 0 1 20-2 110 110 0 0 1 12 3l4 2 3 2 1 4v4c0 3-1 4-2 4l-4-2c-6-2-12-3-19-3-6 0-11 0-14 2s-4 5-4 9c0 3 1 5 3 7s5 4 11 6l14 4c7 3 12 6 15 10s5 9 5 14l-3 12-7 8c-3 3-7 5-11 6l-14 2z"/><path d="M274 144A220 220 0 0 1 4 124c-4-3-1-6 2-4a300 300 0 0 0 263 16c5-2 10 4 5 8z" fill="#f90"/><path d="M287 128c-4-5-28-3-38-1-4 0-4-3-1-5 19-13 50-9 53-5 4 5-1 36-18 51-3 2-6 1-5-2 5-10 13-33 9-38z" fill="#f90"/></svg>',
      },
      // New Technologies
      {
        title: "Astro",
        tech: "Astro.js",
        color: "#BC52EE",
        pos: [-2.5, 0.4, 0], // Far Left Center
        icon: '<svg fill="none" viewBox="0 0 85 107" xmlns="http://www.w3.org/2000/svg"><path fill="#ffffff" d="M27.59 91.136c-4.834-4.418-6.246-13.703-4.232-20.429 3.492 4.241 8.33 5.584 13.342 6.343 7.737 1.17 15.336.732 22.523-2.804.822-.405 1.582-.943 2.48-1.489.675 1.957.85 3.932.615 5.943-.573 4.896-3.01 8.678-6.885 11.545-1.55 1.147-3.19 2.172-4.79 3.253-4.917 3.323-6.247 7.22-4.4 12.888.044.139.084.277.183.614-2.51-1.124-4.344-2.76-5.742-4.911-1.475-2.27-2.177-4.78-2.214-7.498-.019-1.322-.019-2.656-.197-3.96-.434-3.178-1.926-4.601-4.737-4.683-2.884-.084-5.166 1.699-5.771 4.507-.046.216-.113.429-.18.68l.004.001ZM0 69.587s14.314-6.973 28.668-6.973L39.49 29.12c.405-1.62 1.588-2.72 2.924-2.72 1.335 0 2.518 1.1 2.924 2.72L56.16 62.614c17 0 28.668 6.973 28.668 6.973S60.514 3.352 60.467 3.219C59.769 1.261 58.591 0 57.003 0H27.827c-1.588 0-2.718 1.261-3.464 3.22C24.311 3.35 0 69.586 0 69.586Z"/></svg>',
      },
      {
        title: "Styling",
        tech: "Tailwind CSS",
        color: "#38B2AC",
        pos: [0, 2.5, -0.8], // Far Top Center
        icon: '<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12.001 4.8c-3.2 0-5.2 1.6-6 4.8 1.2-1.6 2.6-2.2 4.2-1.8.913.228 1.565.89 2.288 1.624C13.666 10.618 15.027 12 18.001 12c3.2 0 5.2-1.6 6-4.8 -1.2 1.6-2.6 2.2-4.2 1.8 -.913-.228-1.565-.89-2.288-1.624C16.337 6.182 14.976 4.8 12.001 4.8zM6.001 12c-3.2 0-5.2 1.6-6 4.8 1.2-1.6 2.6-2.2 4.2-1.8 .913.228 1.565.89 2.288 1.624 1.177 1.194 2.538 2.576 5.512 2.576 3.2 0 5.2-1.6 6-4.8 -1.2 1.6-2.6 2.2-4.2 1.8 -.913-.228-1.565-.89-2.288-1.624C10.337 13.382 8.976 12 6.001 12z" fill="#38bdf8"/></svg>',
      },
      {
        title: "Backend",
        tech: "Laravel",
        color: "#FF2D20",
        pos: [2.5, -0.4, 0.4], // Far Right Center
        icon: '<svg preserveAspectRatio="xMidYMid" viewBox="0 0 256 264" xmlns="http://www.w3.org/2000/svg"><path d="m255.9 59.6.1 1.1v56.6c0 1.4-.8 2.8-2 3.5l-47.6 27.4v54.2c0 1.4-.7 2.8-2 3.5l-99.1 57-.7.4-.3.1c-.7.2-1.4.2-2.1 0l-.4-.1-.6-.3L2 206c-1.3-.8-2.1-2.2-2.1-3.6V32.7l.1-1.1.2-.4.3-.6.2-.4.4-.5.4-.3c.2 0 .3-.2.5-.3L51.6.6c1.3-.8 2.9-.8 4.1 0L105.3 29c.2 0 .3.2.4.3l.5.3c0 .2.2.4.3.5l.3.4.3.6.1.4.2 1v106l41.2-23.7V60.7c0-.4 0-.7.2-1l.1-.4.3-.7.3-.3.3-.5.5-.3.4-.4 49.6-28.5c1.2-.7 2.8-.7 4 0L254 57l.5.4.4.3.4.5.2.3c.2.2.2.5.3.7l.2.3Zm-8.2 55.3v-47l-17.3 10-24 13.7v47l41.3-23.7Zm-49.5 85v-47l-23.6 13.5-67.2 38.4v47.5l90.8-52.3ZM8.2 39.9V200l90.9 52.3v-47.5l-47.5-26.9-.4-.4c-.2 0-.3-.1-.4-.3l-.4-.4-.3-.4-.2-.5-.2-.5v-.6l-.2-.5V63.6L25.6 49.8l-17.3-10Zm45.5-31L12.4 32.8l41.3 23.7 41.2-23.7L53.7 8.9ZM75 157.3l24-13.8V39.8l-17.3 10-24 13.8v103.6l17.3-10ZM202.3 36.9 161 60.7l41.3 23.8 41.3-23.8-41.3-23.8Zm-4.1 54.7-24-13.8-17.3-10v47l24 13.9 17.3 10v-47Zm-95 106 60.6-34.5 30.2-17.3-41.2-23.8-47.5 27.4L62 174.3l41.2 23.3Z" fill="#FF2D20"/></svg>',
      },
      {
        title: "Mobile",
        tech: "React Native",
        color: "#61dafb", // React Blue
        pos: [0, -2.2, 1.2], // Bottom Center
        icon: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="-11.5 -10.23174 23 20.46348"><circle cx="0" cy="0" r="2.05" fill="#61dafb"/><g stroke="#61dafb" stroke-width="1" fill="none"><ellipse rx="11" ry="4.2"/><ellipse rx="11" ry="4.2" transform="rotate(60)"/><ellipse rx="11" ry="4.2" transform="rotate(120)"/></g></svg>',
      },
    ];

    cards.forEach((cardData, index) => {
      // 3D Anchor
      const anchor = new THREE.Object3D();
      anchor.position.set(...cardData.pos);
      avatarGroup.add(anchor);

      // HTML Element
      const div = document.createElement("div");
      div.className = "tech-card";
      div.innerHTML = `
        <div class="card-icon-wrapper" style="background: ${cardData.color}20">
          <div class="card-icon" style="color: ${cardData.color}">${cardData.icon}</div>
        </div>
        <div class="card-info">
          <span class="card-title">${cardData.title}</span>
          <span class="card-tech">${cardData.tech}</span>
        </div>
      `;

      // CSS2D Object
      const label = new CSS2DObject(div);
      label.position.set(0, 0, 0); // Relative to anchor
      anchor.add(label);

      // Animate Anchor (Floating)
      gsap.to(anchor.position, {
        y: anchor.position.y + 0.3,
        duration: 2 + index * 0.5,
        yoyo: true,
        repeat: -1,
        ease: "power1.inOut",
        delay: index * 0.2,
      });
    });

    // 6. Animation
    const clock = new THREE.Clock();

    let mouseX = 0;
    let mouseY = 0;

    window.addEventListener("mousemove", (event) => {
      mouseX = (event.clientX / window.innerWidth) * 2 - 1;
      mouseY = -(event.clientY / window.innerHeight) * 2 + 1;
    });

    function animate() {
      requestAnimationFrame(animate);

      const time = clock.getElapsedTime();

      // Idle Animation (Floating Group)
      // avatarGroup.position.y = Math.sin(time * 0.8) * 0.1;

      controls.update();

      // Mouse Parallax on Group - DISABLED to allow OrbitControls interaction
      /*
      gsap.to(avatarGroup.rotation, {
        y: mouseX * 0.1,
        x: -mouseY * 0.05,
        duration: 1,
        ease: "power2.out",
      });
      */

      // If we want head tracking, we need to find the bone in the model,
      // which is model specific. For now, we rotate the whole group slightly.

      renderer.render(scene, camera);
      labelRenderer.render(scene, camera);
    }

    animate();

    // Resize
    window.addEventListener("resize", () => {
      if (!container) return;

      camera.aspect = container.clientWidth / container.clientHeight;
      camera.updateProjectionMatrix();

      renderer.setSize(container.clientWidth, container.clientHeight);
      labelRenderer.setSize(container.clientWidth, container.clientHeight);
    });
  }
</script>

<style is:global>
  /* Tech Card Styling */
  .tech-card {
    background: rgba(30, 30, 35, 0.7);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 12px;
    display: flex;
    align-items: center;
    gap: 12px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    min-width: 160px;
    /* transition: transform 0.2s; */
    /* Prevent selection */
    user-select: none;
  }

  /* .tech-card:hover {
    transform: scale(1.05);
    background: rgba(40, 40, 45, 0.8);
    border-color: rgba(255, 255, 255, 0.2);
  } */

  .card-icon-wrapper {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-icon {
    width: 24px;
    height: 24px;
    display: flex;
  }

  .card-icon svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  .card-info {
    display: flex;
    flex-direction: column;
  }

  .card-title {
    font-size: 0.7rem;
    color: #888;
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: 0.5px;
  }

  .card-tech {
    font-size: 0.95rem;
    font-weight: 700;
    color: #fff;
  }
</style>
