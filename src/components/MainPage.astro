---
import Layout from "../layouts/Layout.astro";
import Navbar from "./Navbar.astro";
import Hero from "./Hero.astro";
import Timeline from "./Timeline.astro";
import Services from "./Services.astro";
import Projects from "./Projects.astro";
import Contact from "./Contact.astro";
import ChatWidget from "./ChatWidget";
import VisitorAlert from "./VisitorAlert";
import { db } from "../utils/db";
import Authority from "./Authority.astro";

interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;
const data = db[lang];

// Dynamically set title and description based on language
const title = lang === "es" 
  ? "Yeison Ruiz | Arquitecto de Software & Desarrollador Creativo"
  : "Yeison Ruiz | Software Architect & Creative Developer";

const description = lang === "es"
  ? "Portfolio profesional de Yeison Ruiz, Arquitecto de Software y Desarrollador Creativo especializado en experiencias web inmersivas."
  : "Professional portfolio of Yeison Ruiz, Software Architect and Creative Developer specialized in immersive web experiences.";

const { slugs } = data.ui;
const sectionSlugs = [slugs.home, slugs.timeline, slugs.autoridad, slugs.services, slugs.projects, slugs.contact];
---

<Layout title={title} description={description} lang={lang}>
  <Navbar lang={lang} />

  <ChatWidget client:load lang={lang} />
  <VisitorAlert client:only="react" lang={lang} />

  <main class="relative w-full h-screen overflow-hidden bg-bg-dark">
    <!-- Section 0: Hero -->
    <section id="section-0" class="full-page-section active z-10">
      <Hero lang={lang} />
    </section>

    <!-- Section 1: Timeline -->
    <section
      id="section-1"
      class="full-page-section z-0 opacity-0 pointer-events-none"
    >
      <div
        id="timeline-scroll-container"
        class="w-full h-full overflow-y-auto no-scrollbar"
      >
        <Timeline lang={lang} />
      </div>
    </section>

    <!-- Section 2: Authority -->
    <section
      id="section-2"
      class="full-page-section z-0 opacity-0 pointer-events-none"
    >
      <div
        id="authority-scroll-container"
        class="w-full h-full overflow-y-auto no-scrollbar"
      >
        <Authority lang={lang} />
      </div>
    </section>

    <!-- Section 3: Services -->
    <section
      id="section-3"
      class="full-page-section z-0 opacity-0 pointer-events-none"
    >
      <div
        id="services-scroll-container"
        class="w-full h-full overflow-y-auto no-scrollbar"
      >
        <Services lang={lang} />
      </div>
    </section>

    <!-- Section 4: Projects -->
    <section
      id="section-4"
      class="full-page-section z-0 opacity-0 pointer-events-none"
    >
      <div
        id="projects-scroll-container"
        class="w-full h-full overflow-y-auto no-scrollbar"
      >
        <Projects lang={lang} />
      </div>
    </section>

    <!-- Section 5: Contact -->
    <section
      id="section-5"
      class="full-page-section z-0 opacity-0 pointer-events-none"
    >
      <div
        id="contact-scroll-container"
        class="w-full h-full overflow-y-auto no-scrollbar"
      >
        <Contact lang={lang} />
      </div>
    </section>
  </main>

  <!-- Pass slugs to client-side script -->
  <div id="slugs-data" data-slugs={JSON.stringify(sectionSlugs)} hidden></div>
</Layout>

<style>
  .full-page-section {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { Observer } from "gsap/observer";

  gsap.registerPlugin(ScrollTrigger, Observer);

  const initAnimations = () => {
    const sections = Array.from(
      document.querySelectorAll(".full-page-section"),
    ) as HTMLElement[];
    const slugsData = document.getElementById("slugs-data");
    const sectionSlugs: string[] = slugsData ? JSON.parse(slugsData.getAttribute("data-slugs") || "[]") : ["", "trayectoria", "servicios", "proyectos", "contactenos"];

    let currentIndex = 0;
    let isAnimating = false;
    let lastTransitionTime = 0;

    function gotoSection(index: number, direction: number) {
      if (isAnimating) return;
      isAnimating = true;
      lastTransitionTime = Date.now();

      const currentSection = sections[currentIndex];
      const nextSection = sections[index];

      if (!currentSection || !nextSection) {
        isAnimating = false;
        return;
      }

      gsap.set(nextSection, { zIndex: 10, autoAlpha: 1 });
      gsap.set(currentSection, { zIndex: 0 });

      window.dispatchEvent(
        new CustomEvent("sectionChange", { detail: { index } }),
      );

      const slug = sectionSlugs[index];
      const newHash = slug ? `#${slug}` : window.location.pathname;
      window.history.replaceState(null, "", newHash);

      const tl = gsap.timeline({
        onComplete: () => {
          isAnimating = false;
          currentIndex = index;
          gsap.set(currentSection, { autoAlpha: 0, pointerEvents: "none" });
          gsap.set(nextSection, { pointerEvents: "auto" });
          ScrollTrigger.refresh();
        },
      });

      tl.to(
        currentSection,
        {
          opacity: 0,
          scale: 0.95,
          filter: "blur(10px)",
          duration: 0.8,
          ease: "power3.inOut",
        },
        0,
      );

      tl.fromTo(
        nextSection,
        { opacity: 0, scale: 1.1, filter: "blur(10px)" },
        {
          opacity: 1,
          scale: 1,
          filter: "blur(0px)",
          duration: 0.8,
          ease: "power3.inOut",
        },
        0,
      );
    }

    Observer.create({
      target: window,
      type: "wheel,touch,pointer",
      wheelSpeed: -1,
      onUp: (self) => handleScroll(-1, self.event),
      onDown: (self) => handleScroll(1, self.event),
      tolerance: 20, 
      preventDefault: false,
    });

    let lastWheelEventTime = 0;
    let edgeReachedTime = 0;
    let wasAtEdge = false;

    function handleScroll(direction: number, event?: Event) {
      if (isAnimating) return;

      if (Date.now() - lastTransitionTime < 1500) return;

      if (event && event.target) {
        const target = event.target as HTMLElement;
        if (target.closest("#scene-container")) {
          if (event.type !== "wheel") return;
        }
      }

      const currentSection = sections[currentIndex];
      if (!currentSection) return;

      const scrollContainer = currentSection.querySelector(
        ".overflow-y-auto",
      ) as HTMLElement;

      const now = Date.now();
      const timeSinceLastWheel = now - lastWheelEventTime;
      lastWheelEventTime = now;

      if (scrollContainer) {
        const { scrollTop, scrollHeight, clientHeight } = scrollContainer;
        const tolerance = 5;
        const isAtTop = scrollTop <= tolerance;
        const isAtBottom = Math.ceil(scrollTop + clientHeight) >= scrollHeight - tolerance;

        const isAtEdgeInput = (direction > 0 && isAtBottom) || (direction < 0 && isAtTop);

        if (!isAtEdgeInput) {
          wasAtEdge = false;
          return;
        }

        if (!wasAtEdge) {
          wasAtEdge = true;
          edgeReachedTime = now;
          return;
        }

        if (timeSinceLastWheel < 100) {
          if (now - edgeReachedTime < 1000) return;
        }

        if (direction > 0) {
          if (currentIndex < sections.length - 1) {
            gotoSection(currentIndex + 1, 1);
            wasAtEdge = false;
          }
        } else {
          if (currentIndex > 0) {
            gotoSection(currentIndex - 1, -1);
            wasAtEdge = false;
          }
        }
      } else {
        if (direction > 0 && currentIndex < sections.length - 1) {
          gotoSection(currentIndex + 1, 1);
          wasAtEdge = false;
        } else if (direction < 0 && currentIndex > 0) {
          gotoSection(currentIndex - 1, -1);
          wasAtEdge = false;
        }
      }
    }

    // Handle all anchor clicks dynamically
    const handleAnchorClick = (e: MouseEvent) => {
      const anchor = (e.target as HTMLElement).closest('a[href^="#"]');
      if (!anchor) return;
      
      e.preventDefault();
      const href = anchor.getAttribute("href")?.substring(1) || "";
      const targetIndex = sectionSlugs.findIndex(s => s === href);

      if (targetIndex !== -1 && targetIndex !== currentIndex) {
        gotoSection(targetIndex, targetIndex > currentIndex ? 1 : -1);
      } else if (href === "" && currentIndex !== 0) {
          gotoSection(0, -1);
      }
    };

    document.addEventListener("click", handleAnchorClick);

    // Handle initial hash on load
    const hash = window.location.hash.substring(1);
    if (hash) {
      const targetIndex = sectionSlugs.findIndex(s => s === hash);
      if (targetIndex !== -1 && targetIndex !== currentIndex) {
        gotoSection(targetIndex, 1);
      }
    }
  };

  document.addEventListener("astro:page-load", initAnimations);
  // Also run on initial load if not using view transitions or if they are already handled
  if (document.readyState === 'complete') {
    initAnimations();
  } else {
    window.addEventListener('load', initAnimations);
  }
</script>
