---
import Layout from "../layouts/Layout.astro";
import Navbar from "./Navbar.astro";
import Hero from "./Hero.astro";
import Timeline from "./Timeline.astro";
import Services from "./Services.astro";
import Projects from "./Projects.astro";
import Contact from "./Contact.astro";
import ChatWidget from "./ChatWidget";
import VisitorAlert from "./VisitorAlert";
import { db } from "../utils/db";
import Authority from "./Authority.astro";
import Footer from "./Footer.astro";

interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;
const data = db[lang];

// Dynamically set title and description based on language
const title = lang === "es" 
  ? "Yeison Ruiz | Arquitecto de Software & Desarrollador Creativo"
  : "Yeison Ruiz | Software Architect & Creative Developer";

const description = lang === "es"
  ? "Portfolio profesional de Yeison Ruiz, Arquitecto de Software y Desarrollador Creativo especializado en experiencias web inmersivas."
  : "Professional portfolio of Yeison Ruiz, Software Architect and Creative Developer specialized in immersive web experiences.";

const { slugs } = data.ui;
const sectionSlugs = [slugs.home, slugs.timeline, slugs.certificaciones, slugs.services, slugs.projects, slugs.contact];
---

<Layout title={title} description={description} lang={lang}>
  <Navbar lang={lang} />

  <ChatWidget client:load lang={lang} discordWebhook={import.meta.env.PUBLIC_DISCORD_WEBHOOK_URL} />
  <VisitorAlert client:only="react" lang={lang} />

  <main class="relative w-full h-screen overflow-hidden bg-black md:bg-bg-dark">
    <!-- Section 0: Hero -->
    <section id="section-0" class="full-page-section active z-10">
      <div
        id="hero-scroll-container"
        class="w-full h-full overflow-y-auto no-scrollbar"
      >
        <Hero lang={lang} />
        <Footer lang={lang} />
      </div>
    </section>

    <!-- Section 1: Timeline -->
    <section
      id="section-1"
      class="full-page-section z-0 opacity-0 pointer-events-none"
    >
      <div
        id="timeline-scroll-container"
        class="w-full h-full overflow-y-auto no-scrollbar"
      >
        <Timeline lang={lang} />
        <Footer lang={lang} />
      </div>
    </section>

    <!-- Section 2: Authority -->
    <section
      id="section-2"
      class="full-page-section z-0 opacity-0 pointer-events-none"
    >
      <div
        id="certificaciones-scroll-container"
        class="w-full h-full overflow-y-auto no-scrollbar"
      >
        <Authority lang={lang} />
        <Footer lang={lang} />
      </div>
    </section>

    <!-- Section 3: Services -->
    <section
      id="section-3"
      class="full-page-section z-0 opacity-0 pointer-events-none"
    >
      <div
        id="services-scroll-container"
        class="w-full h-full overflow-y-auto no-scrollbar"
      >
        <Services lang={lang} />
        <Footer lang={lang} />
      </div>
    </section>

    <!-- Section 4: Projects -->
    <section
      id="section-4"
      class="full-page-section z-0 opacity-0 pointer-events-none"
    >
      <div
        id="projects-scroll-container"
        class="w-full h-full overflow-y-auto no-scrollbar"
      >
        <Projects lang={lang} />
        <Footer lang={lang} />
      </div>
    </section>

    <!-- Section 5: Contact -->
    <section
      id="section-5"
      class="full-page-section z-0 opacity-0 pointer-events-none"
    >
      <div
        id="contact-scroll-container"
        class="w-full h-full overflow-y-auto no-scrollbar"
      >
        <Contact lang={lang} />
      </div>
    </section>
  </main>

  <!-- Pass slugs to client-side script -->
  <div id="slugs-data" data-slugs={JSON.stringify(sectionSlugs)} hidden></div>
</Layout>

<style>
  .full-page-section {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { Observer } from "gsap/Observer";

  gsap.registerPlugin(ScrollTrigger, Observer);

  let observerInstance: any;

  const initAnimations = () => {
    if (observerInstance) observerInstance.kill();
    ScrollTrigger.getAll().forEach(t => t.kill());

    const sections = Array.from(document.querySelectorAll(".full-page-section")) as HTMLElement[];
    const slugsData = document.getElementById("slugs-data");
    const sectionSlugs: string[] = slugsData ? JSON.parse(slugsData.getAttribute("data-slugs") || "[]") : [];

    let currentIndex = 0;
    let isAnimating = false;
    let lastTransitionTime = 0;

    // Helper to manage videos
    const manageVideos = (sectionIndex: number) => {
      document.querySelectorAll('video').forEach(v => v.pause());
      const activeSection = sections[sectionIndex];
      if (activeSection) {
        activeSection.querySelectorAll('video').forEach(v => {
          v.play().catch(() => {});
        });
      }
    };

    function gotoSection(index: number, direction: number) {
      if (isAnimating || index < 0 || index >= sections.length) return;
      
      isAnimating = true;
      lastTransitionTime = Date.now();

      const currentSection = sections[currentIndex];
      const nextSection = sections[index];

      // Dispatch event before starting for components to prepare
      window.dispatchEvent(new CustomEvent("sectionChange", { detail: { index } }));

      // Prepare visibility
      gsap.set(nextSection, { zIndex: 10, display: "block", opacity: 0, scale: 1.02, pointerEvents: "auto" });
      gsap.set(currentSection, { zIndex: 0 });

      const slug = sectionSlugs[index];
      window.history.replaceState(null, "", slug ? `#${slug}` : window.location.pathname);

      const tl = gsap.timeline({
        onComplete: () => {
          isAnimating = false;
          currentIndex = index;
          sections.forEach((sec, i) => {
            if (i !== index) {
              gsap.set(sec, { display: "none", pointerEvents: "none" });
            }
          });
          manageVideos(index);
          ScrollTrigger.refresh();
        },
      });

      tl.to(currentSection, { opacity: 0, scale: 0.98, duration: 0.5, ease: "power2.inOut" }, 0);
      tl.to(nextSection, { opacity: 1, scale: 1, duration: 0.5, ease: "power2.inOut" }, 0);
    }

    observerInstance = Observer.create({
      target: window,
      type: "wheel,touch,pointer",
      wheelSpeed: -1,
      onUp: () => handleScroll(-1),
      onDown: () => handleScroll(1),
      tolerance: 15,
      preventDefault: false,
    });

    function handleScroll(direction: number) {
      if (isAnimating || Date.now() - lastTransitionTime < 800) return;

      const currentSection = sections[currentIndex];
      const scrollContainer = currentSection?.querySelector(".overflow-y-auto") as HTMLElement;

      if (scrollContainer) {
        const { scrollTop, scrollHeight, clientHeight } = scrollContainer;
        if (direction > 0 && scrollTop + clientHeight >= scrollHeight - 5) {
          gotoSection(currentIndex + 1, 1);
        } else if (direction < 0 && scrollTop <= 5) {
          gotoSection(currentIndex - 1, -1);
        }
      } else {
        gotoSection(currentIndex + (direction > 0 ? 1 : -1), direction);
      }
    }

    const handleAnchorClick = (e: MouseEvent) => {
      const anchor = (e.target as HTMLElement).closest('a[href^="#"]');
      if (!anchor) return;
      e.preventDefault();
      const href = anchor.getAttribute("href")?.substring(1);
      const targetIndex = href === "" ? 0 : sectionSlugs.indexOf(href!);
      if (targetIndex !== -1 && targetIndex !== currentIndex) {
        gotoSection(targetIndex, targetIndex > currentIndex ? 1 : -1);
      }
    };

    document.addEventListener("click", handleAnchorClick);

    // Initial setup: Ensure only the first section (or hash section) is visible
    sections.forEach((sec, i) => {
      if (i === 0) {
        gsap.set(sec, { display: "block", opacity: 1, zIndex: 10, pointerEvents: "auto" });
      } else {
        gsap.set(sec, { display: "none", opacity: 0, zIndex: 0, pointerEvents: "none" });
      }
    });

    // Initial load from hash
    const hash = window.location.hash.slice(1);
    if (hash) {
      const idx = sectionSlugs.indexOf(hash);
      if (idx !== -1 && idx !== 0) {
        sections.forEach((sec, i) => {
          if (i === idx) {
            gsap.set(sec, { display: "block", opacity: 1, zIndex: 10, pointerEvents: "auto" });
            currentIndex = idx;
          } else {
            gsap.set(sec, { display: "none", opacity: 0, zIndex: 0, pointerEvents: "none" });
          }
        });
        manageVideos(idx);
      }
    } else {
        manageVideos(0);
    }

    document.addEventListener("astro:before-preparation", () => {
      if (observerInstance) observerInstance.kill();
      document.removeEventListener("click", handleAnchorClick);
      ScrollTrigger.getAll().forEach(t => t.kill());
    }, { once: true });
  };

  document.addEventListener("astro:page-load", initAnimations);
  if (document.readyState === 'complete') initAnimations();
  else window.addEventListener('load', () => { if (!observerInstance) initAnimations(); }, { once: true });
</script>
