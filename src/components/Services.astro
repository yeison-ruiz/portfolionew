---
import { db } from "../utils/db";

interface Props {
  lang?: "es" | "en";
}

const { lang = "es" } = Astro.props;
const { services, ui } = db[lang];
---

<section id="servicios" class="relative pt-44 pb-24 overflow-hidden bg-[#050508]">
  <!-- Advanced Background Mesh (From Initial Design) -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <div class="absolute -top-[10%] -left-[10%] w-[40%] h-[40%] bg-primary/10 blur-[180px] rounded-full animate-pulse-slow"></div>
    <div class="absolute top-[20%] -right-[5%] w-[35%] h-[35%] bg-purple-600/5 blur-[150px] rounded-full animate-pulse-slow delay-1000"></div>
    
    <!-- Subtle Grid Pattern -->
    <div class="absolute inset-0 opacity-[0.02] bg-[linear-gradient(to_right,#ffffff_1px,transparent_1px),linear-gradient(to_bottom,#ffffff_1px,transparent_1px)] bg-size-[60px_60px]"></div>
  </div>

  <div class="container mx-auto px-6 relative z-10">
    <!-- Header (Refined Initial Style) -->
    <div class="mb-16 service-header opacity-0 translate-y-10 flex flex-col items-center text-center">
      <div class="inline-flex items-center gap-2.5 px-4 py-1.5 rounded-full bg-white/5 border border-white/10 backdrop-blur-xl mb-6 group cursor-default">
        <div class="w-2 h-2 rounded-full bg-primary shadow-[0_0_10px_var(--color-primary)] animate-pulse"></div>
        <span class="text-[10px] font-black tracking-[0.2em] text-white/60 uppercase">{ui.services.badge}</span>
      </div>

      <h2 class="text-5xl md:text-7xl font-black text-white tracking-tighter leading-none mb-6">
        {ui.services.title} <span class="bg-linear-to-r from-primary via-purple-400 to-blue-400 bg-clip-text text-transparent">{ui.services.titleHighlight}</span>
      </h2>
      
      <p class="text-lg text-text-secondary max-w-xl mx-auto leading-relaxed font-medium">
        {ui.services.description.split(ui.services.descriptionHighlight)[0]}
        <span class="text-white border-b border-primary/50">{ui.services.descriptionHighlight}</span> 
        {ui.services.description.split(ui.services.descriptionHighlight)[1]}
      </p>
    </div>

    <!-- The Staggered Bento Grid (Initial Shape) -->
    <!-- Centered Services Container -->
    <div class="flex flex-wrap justify-center gap-8 mb-24 max-w-7xl mx-auto">
      {
        services.map((service, index) => {
          const bgColor = service.gradient.includes('green') ? 'rgba(34,197,94,0.05)' : 
                         service.gradient.includes('purple') ? 'rgba(168,85,247,0.05)' :
                         service.gradient.includes('yellow') ? 'rgba(234,179,8,0.05)' :
                         service.gradient.includes('blue') ? 'rgba(59,130,246,0.05)' : 'rgba(99,102,241,0.05)';
          
          return (
            <div
              class={`group relative bg-white/3 border border-white/10 rounded-[2.5rem] p-8 md:p-10 hover:bg-white/6 transition-all duration-700 hover:-translate-y-2 hover:shadow-[0_40px_80px_-20px_rgba(0,0,0,0.7)] flex flex-col w-full md:w-[calc(50%-1rem)] lg:w-[calc(33.333%-1.5rem)] min-w-[320px] max-w-md service-card opacity-0 translate-y-20 backdrop-blur-3xl overflow-hidden h-auto`}
              style={`transition-delay: ${index * 100}ms; --card-glow: ${bgColor}`}
            >
              <!-- Ambient Glow -->
              <div class={`absolute -bottom-24 -right-24 w-48 h-48 bg-linear-to-br ${service.gradient} opacity-10 group-hover:opacity-30 blur-[60px] transition-all duration-1000 rounded-full`}></div>

              <div class="relative z-10 flex flex-col h-full">
                <!-- Icon Sphere (Initial Design) -->
                <div class="mb-8 w-16 h-16 relative">
                   <div class={`absolute inset-0 bg-linear-to-br ${service.gradient} blur-xl opacity-30 group-hover:opacity-70 transition-opacity duration-700`}></div>
                   <div class="absolute inset-0 bg-[#0A0A0F] rounded-2xl border border-white/10 flex items-center justify-center shadow-2xl z-10 overflow-hidden">
                      <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(255,255,255,0.05)_1px,transparent_1px)] bg-size-[8px_8px]"></div>
                      <div class="relative z-20 transition-transform duration-700 group-hover:scale-110 group-hover:rotate-3">
                        {service.icon === 'code' && (
                          <svg viewBox="0 0 24 24" class="w-8 h-8 text-white" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                              <polyline points="16 18 22 12 16 6"></polyline>
                              <polyline points="8 6 2 12 8 18"></polyline>
                              <path d="M12 2v4" opacity="0.4"></path>
                              <path d="M12 18v4" opacity="0.4"></path>
                          </svg>
                        )}
                        {service.icon === 'briefcase' && (
                          <svg viewBox="0 0 24 24" class="w-8 h-8 text-white" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                              <rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect>
                              <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
                              <path d="M2 11h20" opacity="0.4"></path>
                          </svg>
                        )}
                        {service.icon === 'palette' && (
                          <svg viewBox="0 0 24 24" class="w-8 h-8 text-white" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                              <circle cx="12" cy="12" r="10"></circle>
                              <circle cx="12" cy="12" r="3" opacity="0.4"></circle>
                          </svg>
                        )}
                        {service.icon === 'chart' && (
                          <svg viewBox="0 0 24 24" class="w-8 h-8 text-white" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                              <path d="M12 20V10"></path>
                              <path d="M18 20V4"></path>
                              <path d="M6 20v-4"></path>
                              <path d="M2 20h20" opacity="0.4"></path>
                          </svg>
                        )}
                        {service.icon === 'cloud' && (
                          <svg viewBox="0 0 24 24" class="w-8 h-8 text-white" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                              <path d="M17.5 19c3.037 0 5.5-2.463 5.5-5.5 0-3-2.5-5.5-5.5-5.5-.38 0-.75.04-1.1.11C15.4 5.04 12.4 3 9 3 4.58 3 1 6.58 1 11c0 .31.02.61.06.91C.96 11.96 0 13.38 0 15c0 2.21 1.79 4 4 4h13.5Z"></path>
                          </svg>
                        )}
                      </div>
                   </div>
                </div>

                <div class="mb-8">
                   <div class="flex items-center gap-3 mb-4">
                      <h3 class="text-2xl md:text-3xl font-black text-white tracking-tight">
                        {service.title}
                      </h3>
                      {service.badge && (
                        <span class={`px-2.5 py-0.5 rounded-full text-[9px] font-black uppercase tracking-widest ${service.badge.color} text-white shadow-lg`}>
                          {service.badge.text}
                        </span>
                      )}
                   </div>
                   
                   <p class="text-gray-400 text-base leading-relaxed font-medium">
                      {service.description}
                   </p>
                </div>

                <!-- Highly Visible Tags (Initial Style) -->
                <div class="pt-6 border-t border-white/10 flex flex-wrap gap-2 mt-auto">
                   {service.tags.map((tag: string) => (
                      <span class="px-3 py-1.5 text-[10px] font-black uppercase tracking-widest text-white/70 bg-white/5 border border-white/10 rounded-lg group-hover:text-white group-hover:bg-white/10 group-hover:border-white/20 transition-all cursor-default">
                        {tag}
                      </span>
                   ))}
                </div>
              </div>
            </div>
          );
        })
      }
    </div>

    <script>
      import gsap from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";

      gsap.registerPlugin(ScrollTrigger);

      const initAnimations = () => {
        const section = document.getElementById("servicios");
        const scrollContainer = "#services-scroll-container";

        if (section) {
          gsap.to(".service-header", {
            opacity: 1,
            y: 0,
            duration: 1.2,
            ease: "power4.out",
            scrollTrigger: {
              trigger: ".service-header",
              scroller: scrollContainer,
              start: "top 85%",
            },
          });

          gsap.to(".service-card", {
            opacity: 1,
            y: 0,
            duration: 1,
            stagger: 0.1,
            ease: "power3.out",
            scrollTrigger: {
              trigger: "#servicios .flex-wrap",
              scroller: scrollContainer,
              start: "top 90%",
            },
          });
        }
      };

      initAnimations();
      document.addEventListener("astro:page-load", initAnimations);
    </script>
  </div>
</section>
