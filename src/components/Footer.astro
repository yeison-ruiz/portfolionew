---
import { db } from "../utils/db";

interface Props {
  lang?: "es" | "en";
}

const { lang = "es" } = Astro.props;
const { personalInfo, ui } = db[lang];
const { slugs } = ui;
---

<footer class="mt-auto border-t border-white/5 bg-[#0A0A0A]/50 backdrop-blur-md">
  <div class="container mx-auto px-6 py-12 md:py-8">
    <div class="flex flex-col md:flex-row justify-between items-center gap-12 md:gap-8 mb-10">
      <!-- Brand Logo (Left on Desktop) -->
      <div class="flex-1 flex justify-center md:justify-start">
        <a
          href={lang === 'es' ? "/" : `/${lang}`}
          class="text-2xl font-black text-white flex items-center gap-1 group tracking-tighter"
        >
          <span class="text-primary group-hover:text-white transition-colors duration-400">&lt;</span>
          <span class="group-hover:text-primary transition-colors duration-400">{personalInfo.name[0]}{personalInfo.lastName[0]}</span>
          <span class="text-primary group-hover:text-white transition-colors duration-400">/&gt;</span>
        </a>
      </div>

      <!-- Navigation Menu & Copyright (Centered) -->
      <div class="flex-2 flex flex-col items-center gap-8 md:gap-6">
        <nav class="flex flex-wrap justify-center items-center gap-x-6 gap-y-4 md:gap-x-8 md:gap-y-3">
          <a
            href={`#${slugs.timeline}`}
            class="text-sm text-gray-400 hover:text-white transition-colors font-medium whitespace-nowrap"
            >{ui.nav.timeline}</a
          >
          <a
            href={`#${slugs.certificaciones}`}
            class="text-sm text-gray-400 hover:text-white transition-colors font-medium whitespace-nowrap"
            >{ui.nav.certificaciones}</a
          >
          <a
            href={`#${slugs.services}`}
            class="text-sm text-gray-400 hover:text-white transition-colors font-medium whitespace-nowrap"
            >{ui.nav.services}</a
          >
          <a
            href={`#${slugs.projects}`}
            class="text-sm text-gray-400 hover:text-white transition-colors font-medium whitespace-nowrap"
            >{ui.nav.projects}</a
          >
          <a
            href={`#${slugs.contact}`}
            class="text-sm text-white hover:text-primary-glow transition-colors font-bold whitespace-nowrap"
            >{ui.nav.contact}</a
          >
        </nav>
        
        <p class="text-xs text-gray-500">
          © {new Date().getFullYear()} {personalInfo.name} {personalInfo.lastName}. {ui.footer.rights}
        </p>
      </div>

      <!-- Social Icons (Right on Desktop) -->
      <div class="flex-1 flex justify-center md:justify-end gap-5">
        {personalInfo.social.github && (
          <a
            href={personalInfo.social.github}
            target="_blank"
            class="text-gray-500 hover:text-white transition-all hover:scale-110"
            aria-label="GitHub"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.28 1.15-.28 2.35 0 3.5-.73 1.02-1.08 2.25-1 3.5 0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
          </a>
        )}
        {personalInfo.social.linkedin && (
          <a
            href={personalInfo.social.linkedin}
            target="_blank"
            class="text-gray-500 hover:text-white transition-all hover:scale-110"
            aria-label="LinkedIn"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
        )}
      </div>
    </div>
  </div>
</footer>
