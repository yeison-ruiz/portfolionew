---
import { db } from "../utils/db";

interface Props {
  lang?: "es" | "en";
}

const { lang = "es" } = Astro.props;
const { personalInfo, ui } = db[lang];
const { slugs } = ui;
---

<footer class="mt-auto border-t border-white/5 bg-[#0A0A0A]/50 backdrop-blur-md">
  <div class="container mx-auto px-6 py-8">
    <div class="flex flex-col items-center py-12 gap-10">
      <!-- Brand Logo -->
      <a
        href={`/${lang}`}
        class="text-3xl font-black text-white flex items-center justify-center gap-1 group tracking-tighter"
      >
        <span class="text-primary group-hover:text-white transition-colors duration-400">&lt;</span>
        <span class="group-hover:text-primary transition-colors duration-400">{personalInfo.name[0]}{personalInfo.lastName[0]}</span>
        <span class="text-primary group-hover:text-white transition-colors duration-400">/&gt;</span>
      </a>

      <!-- Navigation Menu -->
      <nav class="flex flex-wrap justify-center items-center gap-x-10 gap-y-5">
        <a
          href={`#${slugs.timeline}`}
          class="text-sm text-gray-400 hover:text-white transition-all font-medium uppercase tracking-widest"
          >{ui.nav.timeline}</a
        >
        <a
          href={`#${slugs.autoridad}`}
          class="text-sm text-gray-400 hover:text-white transition-all font-medium uppercase tracking-widest"
          >{ui.nav.autoridad}</a
        >
        <a
          href={`#${slugs.services}`}
          class="text-sm text-gray-400 hover:text-white transition-all font-medium uppercase tracking-widest"
          >{ui.nav.services}</a
        >
        <a
          href={`#${slugs.projects}`}
          class="text-sm text-gray-400 hover:text-white transition-all font-medium uppercase tracking-widest"
          >{ui.nav.projects}</a
        >
        <a
          href={`#${slugs.contact}`}
          class="text-sm text-white hover:text-primary-glow transition-all font-bold uppercase tracking-widest"
          >{ui.nav.contact}</a
        >
      </nav>

      <!-- Social Icons -->
      <div class="flex justify-center items-center gap-8">
        {personalInfo.social.github && (
          <a
            href={personalInfo.social.github}
            target="_blank"
            class="text-gray-500 hover:text-white transition-all hover:scale-110"
            aria-label="GitHub"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.28 1.15-.28 2.35 0 3.5-.73 1.02-1.08 2.25-1 3.5 0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
          </a>
        )}
        {personalInfo.social.linkedin && (
          <a
            href={personalInfo.social.linkedin}
            target="_blank"
            class="text-gray-500 hover:text-white transition-all hover:scale-110"
            aria-label="LinkedIn"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
        )}
      </div>

      <!-- Copyright Section -->
      <div class="w-full pt-8 border-t border-white/5 text-center">
        <p class="text-xs text-gray-600 uppercase tracking-widest">
          © {new Date().getFullYear()} {personalInfo.name} {personalInfo.lastName}. {ui.footer.rights}
        </p>
      </div>
    </div>
  </div>
</footer>
