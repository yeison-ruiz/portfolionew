---
import { db } from "../utils/db";

interface Props {
  lang?: "es" | "en";
}

const { lang = "es" } = Astro.props;
const { personalInfo, ui } = db[lang];

const texts = {
    es: {
        badge: "Validación Profesional",
        title: "Autoridad y",
        titleHighlight: "Certificaciones",
        description: "Mis habilidades están respaldadas por las instituciones líderes en Inteligencia Artificial y Tecnología.",
        verify: "Verificar Credencial"
    },
    en: {
        badge: "Professional Validation",
        title: "Authority and",
        titleHighlight: "Certifications",
        description: "My skills are backed by the leading institutions in Artificial Intelligence and Technology.",
        verify: "Verify Credential"
    }
}[lang];
---

<section id={ui.slugs.autoridad} class="relative py-32 overflow-hidden bg-[#050505]">
  <!-- Background Accents -->
  <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-primary/10 rounded-full blur-[120px] -z-10"></div>
  <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-purple-900/10 rounded-full blur-[100px] -z-10"></div>

  <div class="container mx-auto px-6 relative z-10">
    <!-- Header -->
    <div class="text-center mb-24 max-w-4xl mx-auto authority-header opacity-0 translate-y-10">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 backdrop-blur-md mb-8">
        <div class="w-2.5 h-2.5 rounded-full bg-primary shadow-[0_0_10px_var(--color-primary)] animate-pulse"></div>
        <span class="text-xs font-bold tracking-widest text-primary-glow uppercase">{texts.badge}</span>
      </div>

      <h2 class="text-5xl md:text-7xl font-bold mb-8 text-white tracking-tighter leading-tight">
        {texts.title} <span class="bg-linear-to-r from-primary via-purple-400 to-blue-400 bg-clip-text text-transparent">{texts.titleHighlight}</span>
      </h2>

      <p class="text-lg text-text-secondary leading-relaxed max-w-2xl mx-auto">
        {texts.description}
      </p>
    </div>

    <!-- Certifications Grid -->
    <div class="flex flex-wrap justify-center gap-8 max-w-6xl mx-auto">
      {personalInfo.certifications && personalInfo.certifications.map((cert) => (
        <div class="group relative authority-card opacity-0 translate-y-10 w-full md:w-[calc(50%-1rem)] lg:w-[calc(33.333%-1.5rem)] min-w-[320px]">
          <div class="absolute inset-0 bg-linear-to-r from-yellow-500/20 to-primary/20 rounded-4xl blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
          
          <div class="h-full relative bg-white/5 border border-white/10 p-10 rounded-[2.5rem] backdrop-blur-xl hover:bg-white/10 transition-all duration-500 hover:-translate-y-2 flex flex-col">
            <div class="flex items-start justify-between mb-8">
              <div class="p-5 rounded-2xl bg-black/40 border border-white/10 group-hover:border-yellow-500/50 transition-colors">
                {cert.id.startsWith('google') ? (
                  <svg class="w-10 h-10" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                    <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 12-4.53z" fill="#EA4335"/>
                  </svg>
                ) : (
                  <svg class="w-10 h-10" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="12" cy="12" r="10" fill="#FF3F3F"/>
                    <circle cx="12" cy="12" r="6" fill="#fff" opacity="0.4"/>
                    <circle cx="12" cy="12" r="3" fill="#fff"/>
                  </svg>
                )}
              </div>
              <span class="text-xs font-bold text-yellow-500/60 uppercase tracking-widest">{cert.date}</span>
            </div>

            <h3 class="text-2xl font-bold text-white mb-2 group-hover:text-yellow-400 transition-colors uppercase tracking-tight">{cert.title}</h3>
            <p class="text-yellow-500 font-semibold mb-6">{cert.issuer}</p>

            <div class="mt-auto">
              <a 
                href={cert.link} 
                target="_blank" 
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-yellow-500/10 border border-yellow-500/20 text-yellow-500 text-sm font-bold hover:bg-yellow-500 hover:text-black transition-all duration-300 w-full justify-center"
              >
                {texts.verify}
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
    .authority-header, .authority-card {
        transition: all 0.8s cubic-bezier(0.22, 1, 0.36, 1);
    }
</style>

<script>
    import gsap from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    const initAuthority = () => {
        const scroller = "#authority-scroll-container";
        
        gsap.to(".authority-header", {
            opacity: 1,
            y: 0,
            duration: 1,
            scrollTrigger: {
                trigger: ".authority-header",
                scroller: scroller,
                start: "top 80%"
            }
        });

        gsap.to(".authority-card", {
            opacity: 1,
            y: 0,
            duration: 1,
            stagger: 0.2,
            scrollTrigger: {
                trigger: ".authority-card",
                scroller: scroller,
                start: "top 85%"
            }
        });
    }

    document.addEventListener("astro:page-load", () => {
        initAuthority();
        ScrollTrigger.refresh();
    });

    // Also run on first load
    initAuthority();
</script>
