---

<div class="relative w-full h-full flex items-center justify-center py-20 overflow-visible">
  <!-- Central Video Character -->
  <div class="relative w-full max-w-[450px] md:max-w-[550px] flex items-center justify-center">
    <!-- Glow effect behind video -->
    <div class="absolute inset-0 bg-purple-500/20 blur-[130px] rounded-full scale-125 z-0"></div>
    
    <div class="relative z-10 w-full overflow-hidden rounded-3xl border border-white/5 shadow-[0_0_80px_rgba(168,85,247,0.15)] bg-black/20">
        <video
          src="/videoyeison.mp4"
          autoplay
          loop
          muted
          playsinline
          class="w-full h-auto object-cover opacity-90 brightness-110 contrast-105"
        ></video>
        <!-- Fade overlay to blend black edges if any -->
        <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-black/40 pointer-events-none"></div>
    </div>
    
    <!-- Tech Cards -->
    <div class="absolute inset-0 z-20 pointer-events-none">
        {cards.map((card, index) => (
          <div 
            class={`tech-card-html absolute ${card.position} opacity-0 translate-y-4`}
            data-index={index}
          >
            <div class="bg-black/60 backdrop-blur-xl border border-white/10 rounded-2xl p-2.5 md:p-3 flex items-center gap-3 shadow-2xl min-w-[130px] md:min-w-[170px] pointer-events-auto">
              <div class="w-8 h-8 md:w-10 md:h-10 rounded-xl flex items-center justify-center p-1.5 md:p-2 shrink-0" style={`background: ${card.color}20; color: ${card.color}`}>
                <Fragment set:html={card.icon} />
              </div>
              <div class="flex flex-col pr-1 md:pr-2">
                <span class="text-[8px] md:text-[10px] uppercase font-bold text-white/40 tracking-wider">
                  {card.title}
                </span>
                <span class="text-[11px] md:text-sm font-bold text-white leading-tight">
                  {card.tech}
                </span>
              </div>
            </div>
          </div>
        ))}
    </div>
  </div>
</div>

<script>
  import gsap from "gsap";

  const cards = document.querySelectorAll('.tech-card-html');
  
  // Floating animation for each card
  cards.forEach((card, i) => {
    // Initial entrance
    gsap.to(card, {
      opacity: 1,
      y: 0,
      duration: 1,
      delay: 0.5 + (i * 0.1),
      ease: "power3.out"
    });

    // Continuous floating
    gsap.to(card, {
      y: "-=30",
      x: i % 2 === 0 ? "+=10" : "-=10",
      duration: 3 + Math.random() * 2,
      repeat: -1,
      yoyo: true,
      ease: "sine.inOut",
      delay: i * 0.2
    });
  });
</script>

<style>
  .tech-card-html {
    will-change: transform, opacity;
  }
  
  @media (hover: hover) {
    .tech-card-html div {
      transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), background 0.3s ease, border-color 0.3s ease;
    }
    .tech-card-html:hover div {
      transform: scale(1.1) translateY(-5px);
      background: rgba(0, 0, 0, 0.8);
      border-color: rgba(255, 255, 255, 0.2);
    }
  }

  video {
      /* Smooth appearance */
      transition: opacity 1s ease;
  }
</style>
