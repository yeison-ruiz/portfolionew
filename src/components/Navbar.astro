---
import { db } from "../utils/db";

interface Props {
  lang?: "es" | "en";
}

const { lang = "es" } = Astro.props;
const { personalInfo, ui } = db[lang];
const initials = `${personalInfo.name[0]}${personalInfo.lastName[0]}`;

const otherLang = lang === "es" ? "en" : "es";
const langLabel = lang === "es" ? "EN" : "ES";
const langPath = lang === "es" ? "/en" : "/";
---

<header
  class="fixed top-0 md:top-6 left-0 md:left-1/2 md:-translate-x-1/2 w-full md:w-[95%] lg:w-[80%] max-w-5xl z-50 flex items-center justify-between px-6 md:px-8 py-4 md:py-3 bg-bg-dark/60 backdrop-blur-xl border-b md:border border-white/10 md:rounded-full shadow-lg md:shadow-[0_8px_32px_rgba(0,0,0,0.4)] transition-all duration-500"
>
  <!-- Logo -->
  <a
    href={lang === 'es' ? "/" : `/${lang}`}
    class="text-3xl md:text-4xl font-black text-white flex items-center gap-1.5 group tracking-tighter"
  >
    <span class="text-primary group-hover:text-white transition-colors duration-400">&lt;</span>
    <span class="group-hover:text-primary transition-colors duration-400">{initials}</span>
    <span class="text-primary group-hover:text-white transition-colors duration-400">/&gt;</span>
  </a>

  <!-- Navigation Links -->
  <nav class="hidden md:block">
    <ul class="flex items-center gap-2 list-none m-0 p-0">
      <li>
        <a
          href={`#${ui.slugs.timeline}`}
          class="nav-link relative z-10 px-5 py-2.5 text-text-secondary hover:text-white transition-all duration-300 font-medium text-sm inline-flex items-center justify-center rounded-full"
          data-slug={ui.slugs.timeline}
        >
          {ui.nav.timeline}
        </a>
      </li>
      <li>
        <a
          href={`#${ui.slugs.autoridad}`}
          class="nav-link relative z-10 px-5 py-2.5 text-text-secondary hover:text-white transition-all duration-300 font-medium text-sm inline-flex items-center justify-center rounded-full"
          data-slug={ui.slugs.autoridad}
        >
          {ui.nav.autoridad}
        </a>
      </li>
      <li>
        <a
          href={`#${ui.slugs.services}`}
          class="nav-link relative z-10 px-5 py-2.5 text-text-secondary hover:text-white transition-all duration-300 font-medium text-sm inline-flex items-center justify-center rounded-full"
          data-slug={ui.slugs.services}
        >
          {ui.nav.services}
        </a>
      </li>
      <li>
        <a
          href={`#${ui.slugs.projects}`}
          class="nav-link relative z-10 px-5 py-2.5 text-text-secondary hover:text-white transition-all duration-300 font-medium text-sm inline-flex items-center justify-center rounded-full"
          data-slug={ui.slugs.projects}
        >
          {ui.nav.projects}
        </a>
      </li>
    </ul>
  </nav>

  <!-- Actions -->
  <div class="flex items-center gap-4">
    <!-- Language Switcher -->
    <a
      href={langPath}
      class="text-xs font-bold text-text-secondary hover:text-white transition-colors px-3 py-1.5 rounded-full border border-white/10 bg-white/5 backdrop-blur-sm"
      aria-label="Switch language"
    >
      {langLabel}
    </a>

    <!-- CTA Button -->
    <a
      href={`#${ui.slugs.contact}`}
      class="hidden md:inline-flex items-center justify-center px-6 py-2 border border-white/20 rounded-full text-sm font-semibold text-white bg-white/5 hover:bg-white/10 hover:border-white/40 hover:scale-105 active:scale-95 transition-all duration-300"
    >
      {lang === 'es' ? 'Hablemos' : "Let's Talk"}
    </a>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-button"
      class="md:hidden flex flex-col justify-center items-center gap-1.5 w-10 h-10 rounded-full bg-white/5 border border-white/10 text-white z-100"
      aria-label="Toggle menu"
    >
      <span class="w-5 h-0.5 bg-white transition-all duration-300 origin-center"></span>
      <span class="w-5 h-0.5 bg-white transition-all duration-300 origin-center"></span>
      <span class="w-5 h-0.5 bg-white transition-all duration-300 origin-center"></span>
    </button>
  </div>
</header>

<!-- Mobile Content: Navigation Overlay -->
<div
  id="mobile-menu-overlay"
  class="fixed inset-0 z-40 bg-bg-dark/95 backdrop-blur-2xl flex flex-col justify-center items-center p-8 translate-x-full transition-transform duration-500 ease-in-out md:hidden"
>
  <nav class="w-full">
    <ul class="flex flex-col items-center gap-6 list-none m-0 p-0 w-full">
      <li class="w-full text-center">
        <a
          href={`#${ui.slugs.timeline}`}
          class="mobile-nav-link text-2xl font-bold text-gray-400 hover:text-white transition-colors py-2 block w-full"
        >
          {ui.nav.timeline}
        </a>
      </li>
      <li class="w-full text-center">
        <a
          href={`#${ui.slugs.autoridad}`}
          class="mobile-nav-link text-2xl font-bold text-gray-400 hover:text-white transition-colors py-2 block w-full"
        >
          {ui.nav.autoridad}
        </a>
      </li>
      <li class="w-full text-center">
        <a
          href={`#${ui.slugs.services}`}
          class="mobile-nav-link text-2xl font-bold text-gray-400 hover:text-white transition-colors py-2 block w-full"
        >
          {ui.nav.services}
        </a>
      </li>
      <li class="w-full text-center">
        <a
          href={`#${ui.slugs.projects}`}
          class="mobile-nav-link text-2xl font-bold text-gray-400 hover:text-white transition-colors py-2 block w-full"
        >
          {ui.nav.projects}
        </a>
      </li>
      <li class="w-full text-center mt-4">
        <a
          href={`#${ui.slugs.contact}`}
          class="mobile-nav-link inline-flex items-center justify-center px-10 py-4 bg-primary text-white rounded-2xl text-lg font-bold hover:scale-105 active:scale-95 transition-all shadow-[0_8px_32px_rgba(118,39,190,0.4)]"
        >
          {lang === 'es' ? 'Hablemos' : "Let's Talk"}
        </a>
      </li>
    </ul>
  </nav>
</div>

<style>
  /* Active link styles with a subtle glowing pill effect */
  .nav-link.active {
    color: #ffffff;
    background-color: rgba(255, 255, 255, 0.1);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.05);
  }
  
  /* Hover effect for inactive links */
  .nav-link:not(.active):hover {
    background-color: rgba(255, 255, 255, 0.05);
  }

  /* Hamburger Animation */
  #mobile-menu-button.active span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  #mobile-menu-button.active span:nth-child(2) {
    opacity: 0;
    transform: translateX(-10px);
  }
  #mobile-menu-button.active span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }
</style>

<script>
  const navLinks = document.querySelectorAll<HTMLAnchorElement>(".nav-link");

  const resetLinks = () => {
    navLinks.forEach((link) => {
      link.classList.remove("active", "text-white");
      link.classList.add("text-text-secondary");
    });
  };

  const activateLink = (index: number) => {
    resetLinks();
    // Index mapping: 0=Home, 1=Trayectoria/Experience, 2=Autoridad/Authority, 3=Servicios/Services, 4=Proyectos/Projects, 5=Contactenos/Contact
    if (index > 0 && index <= navLinks.length) {
      const activeLink = navLinks[index - 1];
      if (activeLink) {
        activeLink.classList.remove("text-text-secondary");
        activeLink.classList.add("text-white", "active");
      }
    }
  };

  // Listen for section changes from index.astro
  window.addEventListener("sectionChange", ((e: CustomEvent) => {
    activateLink(e.detail.index);
  }) as EventListener);

  // Mobile Menu Logic
  const menuButton = document.getElementById("mobile-menu-button");
  const menuOverlay = document.getElementById("mobile-menu-overlay");
  const mobileLinks = document.querySelectorAll(".mobile-nav-link");

  const toggleMenu = () => {
    const isOpen = menuButton?.classList.contains("active");
    if (isOpen) {
      menuButton?.classList.remove("active");
      menuOverlay?.classList.add("translate-x-full");
      document.body.style.overflow = "";
    } else {
      menuButton?.classList.add("active");
      menuOverlay?.classList.remove("translate-x-full");
      document.body.style.overflow = "hidden";
    }
  };

  menuButton?.addEventListener("click", toggleMenu);

  mobileLinks.forEach(link => {
    link.addEventListener("click", () => {
      menuButton?.classList.remove("active");
      menuOverlay?.classList.add("translate-x-full");
      document.body.style.overflow = "";
    });
  });

  // Initial check
  activateLink(0);
</script>
