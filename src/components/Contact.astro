---
import { db } from "../utils/db";
import ContactVisual from "./ContactVisual.astro";
import Footer from "./Footer.astro";

interface Props {
  lang?: "es" | "en";
}

const { lang = "es" } = Astro.props;
const { personalInfo, ui } = db[lang];
const { slugs } = ui;
---

<section
  id={slugs.contact}
  class="relative min-h-full flex flex-col justify-center pt-32 overflow-hidden"
>
  <!-- Background Elements -->
  <div class="absolute inset-0 bg-black -z-20">
    <!-- Subtle Grid -->
    <div
      class="absolute inset-0 opacity-[0.02]"
      style="background-image: linear-gradient(#ffffff 1px, transparent 1px), linear-gradient(90deg, #ffffff 1px, transparent 1px); background-size: 50px 50px;"
    >
    </div>
  </div>

  <div
    class="container mx-auto px-6 relative z-10 grow flex flex-col justify-center pb-20"
  >
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <!-- Left Side: Globe Visualization -->
      <div
        class="relative h-[500px] md:h-[750px] flex items-center justify-center contact-visual opacity-0 -translate-x-10 w-full"
      >
        <div class="w-full h-full relative">
            <ContactVisual />
        </div>
      </div>

      <!-- Right Side: Contact Form -->
      <div class="contact-form opacity-0 translate-x-10 flex flex-col items-center text-center w-full">
        <h2 class="text-5xl font-bold text-white mb-2">
          {ui.contact.title} <br />
          <span
            class="text-transparent bg-clip-text bg-linear-to-r from-purple-500 to-blue-500"
            >{ui.contact.titleHighlight}</span
          >
        </h2>
        <p class="text-gray-400 text-lg mb-8 max-w-md mx-auto">
          {ui.contact.description}
        </p>

        <form
          class="w-full space-y-6 bg-white/5 p-8 rounded-3xl border border-white/5 backdrop-blur-sm"
        >
          <!-- Name Field -->
          <div class="group">
            <label
              class="block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2 group-focus-within:text-purple-400 transition-colors text-center md:text-left"
              >{ui.contact.form.nameLabel}</label
            >
            <div class="relative">
              <div
                class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-5 w-5 text-gray-500 group-focus-within:text-white transition-colors"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                  ></path></svg
                >
              </div>
              <input
                type="text"
                name="name"
                placeholder={ui.contact.form.namePlaceholder}
                class="w-full bg-[#0a0a0c] border border-white/10 rounded-xl py-3 pl-11 pr-4 text-white placeholder-gray-600 focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500 transition-all"
              />
            </div>
          </div>

          <!-- Email Field -->
          <div class="group">
            <label
              class="block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2 group-focus-within:text-purple-400 transition-colors text-center md:text-left"
              >{ui.contact.form.emailLabel}</label
            >
            <div class="relative">
              <div
                class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-5 w-5 text-gray-500 group-focus-within:text-white transition-colors"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  ></path></svg
                >
              </div>
              <input
                type="email"
                name="email"
                placeholder={ui.contact.form.emailPlaceholder}
                class="w-full bg-[#0a0a0c] border border-white/10 rounded-xl py-3 pl-11 pr-4 text-white placeholder-gray-600 focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500 transition-all"
              />
            </div>
          </div>

          <!-- Phone Field -->
          <div class="group">
            <label
              class="block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2 group-focus-within:text-purple-400 transition-colors text-center md:text-left"
              >{ui.contact.form.phoneLabel}</label
            >
            <div class="relative">
              <div
                class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-5 w-5 text-gray-500 group-focus-within:text-white transition-colors"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                  ></path></svg
                >
              </div>
              <input
                type="tel"
                name="phone"
                placeholder={ui.contact.form.phonePlaceholder}
                class="w-full bg-[#0a0a0c] border border-white/10 rounded-xl py-3 pl-11 pr-4 text-white placeholder-gray-600 focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500 transition-all"
              />
            </div>
          </div>

          <!-- Message Field -->
          <div class="group">
            <label
              class="block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2 group-focus-within:text-purple-400 transition-colors text-center md:text-left"
              >{ui.contact.form.messageLabel}</label
            >
            <div class="relative">
              <div class="absolute top-3 left-0 pl-4 pointer-events-none">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-5 w-5 text-gray-500 group-focus-within:text-white transition-colors"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"
                  ></path></svg
                >
              </div>
              <textarea
                name="message"
                placeholder={ui.contact.form.messagePlaceholder}
                rows="4"
                class="w-full bg-[#0a0a0c] border border-white/10 rounded-xl py-3 pl-11 pr-4 text-white placeholder-gray-600 focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500 transition-all resize-none"
              ></textarea>
            </div>
          </div>

          <button
            class="w-full bg-white text-bg-dark font-bold py-3.5 rounded-xl hover:bg-gray-200 transition-all flex items-center justify-center gap-2 group cursor-pointer"
          >
            {ui.contact.form.send}
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-4 h-4 transform group-hover:translate-x-1 transition-transform"
              viewBox="0 0 24 24"
              fill="currentColor"
              ><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"></path></svg
            >
          </button>
        </form>

        <!-- Social Links (Mini Footer) -->
        <div class="flex gap-4 mt-8 justify-center md:justify-start">
          <a
            href={personalInfo.social.github}
            target="_blank"
            class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-gray-400 hover:text-white hover:bg-white/10 transition-colors"
          >
           <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.28 1.15-.28 2.35 0 3.5-.73 1.02-1.08 2.25-1 3.5 0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
          </a>
          <a
            href={personalInfo.social.linkedin}
            target="_blank"
            class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-gray-400 hover:text-white hover:bg-white/10 transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <Footer lang={lang} />
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const section = document.querySelector('section[id="contactenos"], section[id="contact"]');

  if (section) {
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        scroller: "#contact-scroll-container",
        start: "top 60%",
      },
    });

    tl.to(".contact-visual", {
      opacity: 1,
      x: 0,
      duration: 1,
      ease: "power3.out",
    }).to(
      ".contact-form",
      {
        opacity: 1,
        x: 0,
        duration: 1,
        ease: "power3.out",
      },
      "-=0.8",
    );
  }

  // --- FORM LOGIC TO DISCORD ---
  const contactForm = document.querySelector('.contact-form form') as HTMLFormElement;
  const submitBtn = contactForm?.querySelector('button');

  contactForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!submitBtn) return;

    const originalText = submitBtn.innerText;
    const formData = new FormData(contactForm);
    const data = {
      name: (formData.get('name') as string),
      email: (formData.get('email') as string),
      phone: (formData.get('phone') as string),
      message: (formData.get('message') as string)
    };

    if (!data.name || !data.email || !data.message) return;

    // Prevent multiple submissions
    if (sessionStorage.getItem('contact_form_sent')) {
      alert(window.location.pathname.includes('/en') ? "Message already sent!" : "¡Mensaje ya enviado!");
      return;
    }

    try {
      submitBtn.disabled = true;
      submitBtn.innerText = "⏳ ...";

      const webhook = import.meta.env.PUBLIC_DISCORD_WEBHOOK_URL;
      
      const discordMessage = {
        embeds: [{
          title: "📩 ¡Nuevo Mensaje de Contacto!",
          color: 3447003, // Blue
          fields: [
            { name: "👤 Nombre", value: data.name, inline: true },
            { name: "📧 Email", value: data.email, inline: true },
            { name: "📞 Teléfono", value: data.phone || "N/A", inline: true },
            { name: "💬 Mensaje", value: data.message },
            { name: "🕒 Hora", value: new Date().toLocaleString() }
          ],
          footer: { text: "Yeison Portfolio Contact Form" }
        }]
      };

      await fetch(webhook, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(discordMessage)
      });

      sessionStorage.setItem('contact_form_sent', 'true');
      submitBtn.innerText = "✅ ¡Enviado!";
      contactForm.reset();
      
      setTimeout(() => {
        submitBtn.disabled = false;
        submitBtn.innerText = originalText;
      }, 3000);

    } catch (error) {
      console.error('Error:', error);
      submitBtn.disabled = false;
      submitBtn.innerText = "❌ Error";
    }
  });
</script>
