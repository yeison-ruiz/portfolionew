---
import { db } from "../utils/db";

interface Props {
  lang?: "es" | "en";
}

const { lang = "es" } = Astro.props;
const { timeline, ui } = db[lang];
---

<section id="trayectoria" class="relative py-32 overflow-hidden">
  <!-- Dynamic Background Effects -->
  <div
    class="absolute top-1/4 left-0 w-[500px] h-[500px] bg-primary/20 rounded-full blur-[120px] -z-10 animate-pulse-slow"
  >
  </div>
  <div
    class="absolute bottom-1/4 right-0 w-[500px] h-[500px] bg-purple-900/20 rounded-full blur-[120px] -z-10 animate-pulse-slow delay-1000"
  >
  </div>

  <div class="container mx-auto px-6 relative z-10">
    <!-- Header -->
    <div class="text-center mb-32 max-w-4xl mx-auto service-header opacity-0 translate-y-10">
      <div
        class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 backdrop-blur-md mb-8"
      >
        <div class="w-2.5 h-2.5 rounded-full bg-primary shadow-[0_0_10px_var(--color-primary)] animate-pulse"></div>
        <span
          class="text-xs font-bold tracking-widest text-primary-glow uppercase"
          >{ui.timeline.badge}</span
        >
      </div>

      <h2 class="text-5xl md:text-7xl font-bold mb-8 text-white tracking-tighter leading-tight">
        {ui.timeline.title} <span
          class="bg-linear-to-r from-primary via-purple-400 to-blue-400 bg-clip-text text-transparent"
          >{ui.timeline.titleHighlight}</span
        >
      </h2>

      <p class="text-lg text-text-secondary leading-relaxed max-w-2xl mx-auto">
        {ui.timeline.description}
      </p>
    </div>

    <!-- Timeline Container -->
    <div class="relative max-w-5xl mx-auto">
      <!-- Central Line -->
      <div
        class="absolute left-1/2 transform -translate-x-1/2 h-full w-[2px] bg-linear-to-b from-primary via-purple-500/50 to-transparent hidden md:block"
      >
      </div>

      <!-- Timeline Items -->
      <div class="space-y-32">
        {timeline.map((item, index) => (
            <div
            class="relative flex flex-col md:flex-row items-center justify-between group timeline-item"
            >
            <!-- Background Year (Parallax) -->
            <div
                class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 text-[140px] md:text-[200px] font-black text-white/5 select-none pointer-events-none z-0 hidden md:block italic tracking-tighter"
            >
                {item.year.split(" - ").pop()}
            </div>

            <!-- Content Card -->
            <div class={`w-full md:w-5/12 ${item.align === 'left' ? 'order-2 md:order-1' : 'order-3'}`}>
                  <div
                  class={`bg-[#0D0D11] border border-white/5 p-8 md:p-10 rounded-[2.5rem] backdrop-blur-xl transition-all duration-700 hover:bg-[#121218] hover:-translate-y-3 hover:shadow-[0_40px_80px_-20px_rgba(0,0,0,0.6)] hover:border-white/10 z-10 relative overflow-hidden ${item.align === 'left' ? 'timeline-card-left' : 'timeline-card-right'}`}
                  >
                    <!-- Small Glow -->
                    <div class="absolute top-0 left-0 w-32 h-32 bg-primary/10 blur-[60px] -z-10 group-hover:bg-primary/20 transition-colors"></div>

                    <div class="flex items-center justify-between mb-8">
                       <div class="flex flex-col">
                          <span class="text-primary-glow text-xs font-bold tracking-widest uppercase mb-2 block">{item.year}</span>
                          <h3 class="text-2xl md:text-3xl font-extrabold text-white leading-tight">
                              {item.title}
                          </h3>
                       </div>
                       <div class="p-4 rounded-2xl bg-white/5 border border-white/5 text-white/80 shrink-0 group-hover:scale-110 group-hover:rotate-3 transition-transform duration-500">
                          <svg
                              xmlns="http://www.w3.org/2000/svg"
                              class="w-6 h-6"
                              fill="none"
                              viewBox="0 0 24 24"
                              stroke="currentColor"
                          >
                              <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              stroke-width="2"
                              d={item.icon}
                              ></path>
                          </svg>
                       </div>
                    </div>

                    <p class="text-primary font-bold text-lg mb-4">{item.company}</p>

                    <p class="text-gray-400 mb-8 leading-relaxed text-sm md:text-base">
                        {item.description}
                    </p>

                    <div class="flex flex-wrap gap-2">
                        {item.tags.map((tag: string) => (
                            <span
                            class="px-4 py-1.5 text-[10px] sm:text-xs font-bold tracking-widest uppercase rounded-xl bg-white/5 border border-white/5 text-gray-450 hover:bg-white/10 hover:text-white transition-all cursor-default"
                            >{tag}</span
                            >
                        ))}
                    </div>

                    <!-- Subtle corner icon -->
                    <div class="absolute bottom-6 right-6 opacity-0 group-hover:opacity-10 transition-opacity">
                       <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor">
                          <path d={item.icon} />
                       </svg>
                    </div>
                  </div>
            </div>

            <!-- Center Dot (Interactive Node) -->
            <div
                class="absolute left-1/2 transform -translate-x-1/2 w-8 h-8 rounded-full bg-[#0D0D11] border-4 border-white/10 md:flex items-center justify-center hidden z-20 group-hover:border-primary transition-all duration-500 shadow-[0_0_20px_rgba(0,0,0,0.8)]"
            >
                <div class="w-2 h-2 rounded-full bg-primary-glow group-hover:scale-[2.5] transition-transform duration-500 shadow-[0_0_15px_var(--color-primary)]"></div>
            </div>

            <!-- Empty spacer for the other side on desktop -->
            <div class={`w-full md:w-5/12 hidden md:block ${item.align === 'left' ? 'order-3' : 'order-1'}`}></div>
            </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const initAnimations = () => {
    const entries = document.querySelectorAll(".timeline-item");
    const scrollContainer = "#timeline-scroll-container";

    entries.forEach((entry) => {
      // Animate Cards
      const cardLeft = entry.querySelector(".timeline-card-left");
      const cardRight = entry.querySelector(".timeline-card-right");
      const dot = entry.querySelector(".rounded-full.border-4");
      const year = entry.querySelector(".text-\\[140px\\], .text-\\[200px\\]");

      if (cardLeft) {
        gsap.fromTo(
          cardLeft,
          { x: -50, opacity: 0 },
          {
            x: 0,
            opacity: 1,
            duration: 1,
            ease: "power3.out",
            scrollTrigger: {
              trigger: entry,
              scroller: scrollContainer,
              start: "top 80%",
            },
          },
        );
      }

      if (cardRight) {
        gsap.fromTo(
          cardRight,
          { x: 50, opacity: 0 },
          {
            x: 0,
            opacity: 1,
            duration: 1,
            ease: "power3.out",
            scrollTrigger: {
              trigger: entry,
              scroller: scrollContainer,
              start: "top 80%",
            },
          },
        );
      }

      // Animate Central Dot
      if (dot) {
        gsap.fromTo(
          dot,
          { scale: 0, opacity: 0 },
          {
            scale: 1,
            opacity: 1,
            duration: 0.5,
            delay: 0.3,
            ease: "back.out(1.7)",
            scrollTrigger: {
              trigger: entry,
              scroller: scrollContainer,
              start: "top 80%",
            },
          },
        );
      }

      // Parallax Year effect
      if (year) {
        gsap.to(year, {
          y: 50,
          ease: "none",
          scrollTrigger: {
            trigger: entry,
            scroller: scrollContainer,
            start: "top bottom",
            end: "bottom top",
            scrub: true,
          },
        });
      }
    });
  };

  initAnimations();
  document.addEventListener("astro:page-load", initAnimations);
</script>
