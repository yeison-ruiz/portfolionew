---
import { db } from "../utils/db";
import "../styles/global.css";

const lang = "es";
const { personalInfo, ui, services, timeline, projects } = db[lang];
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CV - {personalInfo.name} {personalInfo.lastName}</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');
    
    body {
      font-family: 'Inter', sans-serif;
      background-color: #f3f4f6; /* bg-gray-100 for screen */
      color: #111827;
    }
    
    .a4-page {
      width: 210mm;
      min-height: 297mm;
      background: white;
      margin: 2rem auto;
      box-shadow: 0 10px 25px rgba(0,0,0,0.1);
      padding: 0;
      position: relative;
    }

    /* Ocultar barra de scroll en modo visualización web */
    ::-webkit-scrollbar {
      width: 8px;
    }
    ::-webkit-scrollbar-track {
      background: #f1f1f1; 
    }
    ::-webkit-scrollbar-thumb {
      background: #c084fc; 
      border-radius: 4px;
    }

    /* Print CSS */
    @media print {
      @page {
        size: A4;
        margin: 0;
      }
      body {
        margin: 0;
        background-color: white;
        -webkit-print-color-adjust: exact !important;
        print-color-adjust: exact !important;
      }
      .a4-page {
        margin: 0;
        box-shadow: none;
        width: 100%;
        min-height: 100%;
        page-break-after: avoid;
      }
      .no-print {
        display: none !important;
      }
      .page-break {
        page-break-before: always;
      }
    }
  </style>

</head>
<body class="bg-[#f0f2f5] text-gray-800 antialiased print:bg-white flex flex-col items-center py-10 print:py-0">

  <!-- Botones de Acción (Ocultos al imprimir) -->
  <div class="fixed bottom-8 right-8 no-print z-50 flex flex-col gap-4">
    <button onclick="window.print()" class="bg-gray-900 hover:bg-black text-white px-6 py-4 rounded-2xl shadow-2xl font-black flex items-center gap-3 transition-transform hover:-translate-y-1 tracking-widest uppercase text-xs">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
      Descargar CV
    </button>
  </div>
  
  <div class="fixed top-8 left-8 no-print z-50">
    <a href="/" class="bg-white hover:bg-gray-50 text-gray-900 px-5 py-3 rounded-2xl shadow-xl font-bold flex items-center gap-2 transition-transform hover:-translate-y-1 text-xs border border-gray-100 uppercase tracking-widest">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
      Website
    </a>
  </div>

  <!-- PÁGINA 1: HOJA DE VIDA -->
  <div class="a4-page flex flex-col overflow-hidden bg-white relative">
    
    <!-- Super Graphic Header -->
    <header class="p-10 pb-8 flex items-start gap-8 z-10 relative">
      <!-- Accent Top Bar -->
      <div class="absolute top-0 right-10 w-40 h-[6px] bg-gray-900"></div>
      
      <!-- Logo Monogram -->
      <div class="w-20 h-20 rounded-2xl text-white flex items-center justify-center shrink-0 translate-y-2 relative overflow-hidden bg-gray-900 shadow-xl shadow-gray-200">
        <!-- Subtítulo de fondo texturado en el logo -->
        <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(#fff 1px, transparent 1px); background-size: 8px 8px;"></div>
        <span class="text-[36px] font-black tracking-tighter leading-none relative z-10">YR<span class="text-primary">.</span></span>
      </div>

      <div class="flex-1">
        <h1 class="text-[58px] font-black text-gray-900 leading-[0.8] tracking-tighter uppercase mb-4">
          Yeison <br /> <span class="text-primary relative inline-block">Ruiz</span>
        </h1>
        <h2 class="text-[13px] font-black text-gray-400 uppercase tracking-[0.3em] flex items-center gap-3">
          <span class="w-5 h-[2px] bg-gray-300 inline-block rounded-full"></span>
          Full Stack Developer · Web Apps, SEO & Performance
        </h2>
      </div>

      <div class="text-[10px] text-gray-400 font-bold space-y-2 uppercase tracking-widest border-l-2 border-gray-100 pl-8 mt-4 flex flex-col justify-end">
        <a href={`mailto:${personalInfo.social.email}`} class="flex items-center gap-2.5 hover:text-primary transition-colors text-gray-600">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-gray-900"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <span class="text-[12px] lowercase tracking-normal font-medium">{personalInfo.social.email}</span>
        </a>
        <a href={personalInfo.social.github} target="_blank" class="flex items-center gap-2.5 hover:text-primary transition-colors text-gray-600">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-gray-900"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.28 1.15-.28 2.35 0 3.5-.73 1.02-1.08 2.25-1 3.5 0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
          <span class="text-[12px] lowercase tracking-normal font-medium">github.com/yeisonruiz</span>
        </a>
        <a href="https://yeisonruiz.dev" target="_blank" class="flex items-center gap-2.5 hover:text-primary transition-colors text-gray-600">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-gray-900"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
          <span class="text-[12px] lowercase tracking-normal text-primary font-black">yeisonruiz.dev</span>
        </a>
      </div>
    </header>

    <div class="flex-1 flex z-10 relative">
      <!-- Right Sidebar Background -->
      <div class="absolute top-0 right-0 w-[38%] h-full bg-[#f8f9fc] border-t border-l border-gray-100/80 -z-10 rounded-tl-[40px]"></div>
      
      <!-- COLUMNA PRINCIPAL (62%) -->
      <div class="w-[62%] pl-14 pr-10 py-6 flex flex-col gap-6">
        
        <!-- Perfil -->
        <section>
          <h3 class="flex items-center gap-3 text-[14px] font-black text-gray-900 uppercase tracking-[0.25em] mb-4">
            <span class="w-1 h-3 bg-primary block rounded-full"></span>
            Resumen Ejecutivo
          </h3>
          <p class="text-gray-600 leading-[1.7] text-[14.5px] text-justify font-medium">
            Full Stack Developer con más de 12 años de experiencia construyendo plataformas digitales inmersivas. Especialista en la metodología SDD (Speed Driven Development), SEO de alto rendimiento e integración de Inteligencia Artificial para potenciar procesos. Construyo arquitecturas resilientes con ecosistemas modernos como React, Next.js y Node.
          </p>
        </section>

        <!-- Experiencia -->
        <section>
          <h3 class="flex items-center gap-3 text-[15px] font-black text-gray-900 uppercase tracking-[0.25em] mb-7">
            <span class="w-1 h-3 bg-primary block rounded-full"></span>
            Trayectoria Profesional
          </h3>
          
          <div class="flex flex-col gap-6">
            {timeline.filter(t => !t.isSpecial).slice(0, 4).map(item => (
              <div class="relative pl-8 border-l-2 border-gray-100">
                <div class="absolute w-3 h-3 bg-white border-[3px] border-primary rounded-full -left-[7.5px] top-1.5 shadow-sm"></div>
                
                <div class="flex items-center gap-3 mb-1.5">
                  <h4 class="font-black text-gray-900 text-[18px] tracking-tight whitespace-nowrap">{item.title}</h4>
                  <div class="h-px bg-gray-200 flex-1"></div>
                  <span class="text-[11px] font-black text-gray-400 uppercase tracking-[0.2em]">{item.year}</span>
                </div>
                <h5 class="text-[12px] font-black text-primary mb-2.5 uppercase tracking-[0.15em]">{item.company}</h5>
                <p class="text-[14px] text-gray-600 leading-[1.6] mb-4 text-justify font-medium line-clamp-3">{item.description}</p>
                <div class="flex flex-wrap gap-2">
                  {item.tags.slice(0, 6).map(tag => (
                    <span class="text-[9px] bg-gray-50 text-gray-600 px-2 py-0.5 rounded-sm font-bold uppercase tracking-widest border border-gray-100">{tag}</span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </section>
      </div>

      <!-- COLUMNA LATERAL (38%) -->
      <div class="w-[38%] pr-14 pl-10 py-6 flex flex-col gap-6 relative">
        
        <!-- Core Skills -->
        <section>
          <div class="flex items-center gap-2 mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-gray-900"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
            <h3 class="text-[11px] font-black text-gray-900 uppercase tracking-[0.25em]">Stack Principal</h3>
          </div>
          <div class="flex flex-col gap-3.5">
            {services.slice(0, 5).map(s => (
              <div>
                <h4 class="font-black text-[8px] text-gray-400 mb-1.5 uppercase tracking-widest leading-none">
                  {s.title.replace(" Desarrollo", "").replace(" Diseño ", "").replace("Sitios Web ", "").replace("Auditoría ", "").replace(" e Integraciones", "")}
                </h4>
                <div class="flex flex-wrap gap-1">
                  {s.tags.slice(0, 6).map(t => (
                    <span class="text-[11px] bg-white border border-gray-200 text-gray-800 px-2 py-0.5 rounded shadow-sm font-bold">{t}</span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </section>

        <!-- Certificaciones -->
        <section>
          <div class="flex items-center gap-2 mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-gray-900"><path d="M3 15v4c0 1.1.9 2 2 2h14a2 2 0 0 0 2-2v-4M17 9l-5 5-5-5M12 12.8V2.5"/></svg>
            <h3 class="text-[11px] font-black text-gray-900 uppercase tracking-[0.25em]">Certificaciones</h3>
          </div>
          <div class="flex flex-col gap-1.5">
            {personalInfo.certifications?.map(cert => (
              <div class="flex items-start gap-2">
                <div class="text-primary mt-0.5 shrink-0 bg-white shadow-sm border border-gray-100 p-0.5 rounded-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                </div>
                <div class="flex flex-col">
                  <span class="font-black text-gray-800 text-[12px] leading-tight wrap-break-word">{cert.shortName || cert.title}</span>
                  <span class="text-[9.5px] text-gray-400 font-extrabold uppercase tracking-widest leading-none">
                    {cert.issuer} • {cert.date}
                  </span>
                </div>
              </div>
            ))}
          </div>
        </section>

        <!-- Idiomas -->
        <section class="mt-auto pt-4">
          <div class="flex items-center gap-2 mb-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-gray-900"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            <h3 class="text-[11px] font-black text-gray-900 uppercase tracking-[0.25em]">Idiomas</h3>
          </div>
          <div class="grid gap-2">
            <div class="flex justify-between items-center bg-white px-3 py-1.5 rounded uppercase shadow-sm border border-gray-100">
              <span class="text-gray-400 tracking-widest text-[8px] font-black">Español</span>
              <span class="text-[10px] font-black text-gray-800">Nativo</span>
            </div>
          </div>
        </section>
      </div>
    </div>
  </div>
  
  <!-- PÁGINA 2: CASOS DE ESTUDIO -->
  <div class="a4-page flex flex-col page-break bg-white relative overflow-hidden">
    <!-- Accent corner -->
    <div class="absolute top-0 right-0 w-64 h-64 bg-slate-50 rounded-bl-full -z-10"></div>
    
    <header class="pt-16 px-14 pb-10 flex items-center justify-between relative z-10 border-b border-gray-100 mb-8">
      <div class="flex items-center gap-6">
         <!-- Giant Number Graphic -->
         <span class="text-[80px] font-black text-gray-100 tracking-tighter leading-none select-none">02</span>
         <div class="pb-2">
           <h2 class="text-[36px] font-black text-gray-900 uppercase tracking-tighter leading-none mb-2">Showcase <span class="text-primary">.</span></h2>
           <p class="text-gray-500 text-[10px] font-black uppercase tracking-[0.3em] pl-1">Casos de Estudio & Proyectos Técnicos</p>
         </div>
      </div>
      <!-- Decorative Line -->
      <div class="w-16 h-1 bg-gray-900 mb-6"></div>
    </header>
    
    <div class="px-14 flex-1 grid grid-cols-2 gap-x-12 gap-y-10 content-start relative z-10">
      {projects.map(p => (
        <div class="flex flex-col group">
          <!-- Image Box (Lookbook style, strict aspect ratio, prominent shadow) -->
          <div class={`aspect-[16/10] ${p.category.toUpperCase().includes('MOBILE') ? 'bg-gray-900 shadow-inner' : 'bg-gray-100'} rounded-xl overflow-hidden mb-6 relative drop-shadow-[0_12px_20px_rgba(0,0,0,0.06)] border border-gray-200/60 p-1 group`}>
             <div class={`w-full h-full rounded-lg overflow-hidden relative flex items-center justify-center ${p.category.toUpperCase().includes('MOBILE') ? 'p-3' : ''}`}>
               {p.images && p.images.length > 0 && (
                 <img 
                   src={p.images[0]} 
                   alt={p.title} 
                   class={`${p.category.toUpperCase().includes('MOBILE') ? 'h-full w-auto object-contain rounded-md shadow-2xl' : 'w-full h-full object-cover object-top'} group-hover:scale-110 transition-transform duration-700 ease-out`} 
                 />
               )}
             </div>
          </div>
          
          <!-- Text Box -->
          <div class="pr-4 flex flex-col flex-1">
            <span class="text-[8px] text-primary font-black tracking-[0.25em] uppercase mb-2 block">{p.category}</span>
            <h3 class="font-black text-gray-900 text-[18px] mb-2.5 tracking-tight">{p.title}</h3>
            <p class="text-[12.5px] text-gray-500 mb-5 text-justify font-medium leading-[1.8]">{p.description}</p>
            <div class="flex flex-wrap gap-1.5 mt-auto">
              {p.tech.slice(0, 5).map(t => (
                <span class="text-[8px] border border-gray-200 text-gray-600 px-2 py-[3px] rounded-sm font-bold uppercase tracking-widest bg-gray-50">{t}</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
    
    <footer class="mt-8 py-10 text-center border-t border-gray-100 mx-14 select-none">
      <p class="text-[9px] text-gray-400 font-black uppercase tracking-[0.35em] mb-2">
        Explora la experiencia interactiva en
      </p>
      <a href="https://yeisonruiz.dev" class="text-gray-900 font-black text-2xl hover:text-primary transition-colors tracking-tighter decoration-4 underline-offset-[6px] hover:underline">yeisonruiz.dev</a>
    </footer>
  </div>

</body>
</html>
