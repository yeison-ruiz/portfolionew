---
import { db } from "../utils/db";
import "../styles/global.css";

const lang = "es";
const { personalInfo, ui, services, timeline, projects } = db[lang];
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CV - {personalInfo.name} {personalInfo.lastName}</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');
    
    body {
      font-family: 'Inter', sans-serif;
      background-color: #f3f4f6; /* bg-gray-100 for screen */
      color: #111827;
    }
    
    .a4-page {
      width: 210mm;
      min-height: 297mm;
      background: white;
      margin: 2rem auto;
      box-shadow: 0 10px 25px rgba(0,0,0,0.1);
      padding: 0;
      position: relative;
    }

    /* Ocultar barra de scroll en modo visualización web */
    ::-webkit-scrollbar {
      width: 8px;
    }
    ::-webkit-scrollbar-track {
      background: #f1f1f1; 
    }
    ::-webkit-scrollbar-thumb {
      background: #c084fc; 
      border-radius: 4px;
    }

    /* Print CSS */
    @media print {
      @page {
        size: A4;
        margin: 0;
      }
      body {
        margin: 0;
        background-color: white;
        -webkit-print-color-adjust: exact !important;
        print-color-adjust: exact !important;
      }
      .a4-page {
        margin: 0;
        box-shadow: none;
        width: 100%;
        min-height: 100%;
        page-break-after: avoid;
      }
      .no-print {
        display: none !important;
      }
      .page-break {
        page-break-before: always;
      }
    }
  </style>

</head>
<body class="antialiased text-gray-800">

  <!-- Print Button (Hidden in Print) -->
  <div class="fixed bottom-8 right-8 no-print z-50">
    <button onclick="window.print()" class="bg-primary hover:bg-purple-800 text-white px-6 py-4 rounded-full shadow-2xl font-bold flex items-center gap-3 transition-transform hover:scale-105">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"></polyline><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path><rect x="6" y="14" width="12" height="8"></rect></svg>
      Guardar como PDF / Imprimir
    </button>
  </div>
  
  <div class="fixed top-8 left-8 no-print z-50">
    <a href="/" class="bg-gray-800 hover:bg-gray-700 text-white px-4 py-2 rounded-full shadow-lg font-bold flex items-center gap-2 transition-transform hover:scale-105 text-sm">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
      Volver al Portafolio
    </a>
  </div>

  <!-- HOJA 1: CV PRINCIPAL -->
  <div class="a4-page flex flex-col">
    <!-- Header -->
    <header class="bg-[#0a0a0A] text-white p-10 flex items-center justify-between">
      <div>
        <h1 class="text-5xl font-black tracking-tighter mb-2 uppercase">{personalInfo.name} <span class="text-primary">{personalInfo.lastName}</span></h1>
        <h2 class="text-xl font-medium text-gray-300 transform -translate-y-1"><Fragment set:html={personalInfo.title} /></h2>
      </div>
      <div class="text-right text-sm text-gray-300 space-y-1.5">
        <p class="flex items-center justify-end gap-2 font-medium">
          {personalInfo.social.email}
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </p>
        <p class="flex items-center justify-end gap-2 font-medium">
          {personalInfo.social.github.replace("https://", "")}
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.28 1.15-.28 2.35 0 3.5-.73 1.02-1.08 2.25-1 3.5 0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
        </p>
        <p class="flex items-center justify-end gap-2 font-medium">
          {personalInfo.availability.status}
          <span class="relative flex h-3 w-3">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-3 w-3 bg-green-500"></span>
          </span>
        </p>
      </div>
    </header>

    <div class="px-10 py-8 flex-1 grid grid-cols-12 gap-8">
      
      <!-- Left Column (Experiencia) -->
      <div class="col-span-8 space-y-8">
        <!-- Profile -->
        <section>
          <h3 class="text-sm font-black text-gray-900 uppercase tracking-widest border-b-2 border-primary pb-2 mb-4">Perfil Profesional</h3>
          <p class="text-gray-700 leading-relaxed text-sm text-justify">
            {personalInfo.description} {ui.services.description} Experto en crear ecosistemas digitales escalables integrando arquitecturas modernas y diseño centrado en el usuario.
          </p>
        </section>

        <!-- Experience -->
        <section>
          <h3 class="text-sm font-black text-gray-900 uppercase tracking-widest border-b-2 border-primary pb-2 mb-4 mt-2">Experiencia Profesional</h3>
          <div class="space-y-6">
            {timeline.filter(t => !t.isSpecial).map(item => (
              <div class="relative pl-5 border-l-2 border-gray-200">
                <div class="absolute w-2.5 h-2.5 rounded-full bg-primary -left-[5.5px] top-1.5 shadow-[0_0_0_3px_white]"></div>
                <div class="flex justify-between items-baseline mb-1 gap-2">
                  <h4 class="font-extrabold text-gray-900 leading-tight">{item.title}</h4>
                  <span class="text-[10px] font-bold text-primary bg-primary/10 px-2 py-0.5 rounded shrink-0">{item.year}</span>
                </div>
                <h5 class="text-xs font-bold text-gray-600 mb-2">{item.company}</h5>
                <p class="text-xs text-gray-700 leading-relaxed mb-2 text-justify">{item.description}</p>
                <div class="flex flex-wrap gap-1">
                  {item.tags.map(tag => (
                    <span class="text-[9px] bg-gray-100 text-gray-600 px-2 py-1 rounded uppercase tracking-wider font-semibold">{tag}</span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </section>
      </div>

      <!-- Right Column (Skills & Certs) -->
      <div class="col-span-4 space-y-8">
        <!-- Stats -->
        <section>
          <h3 class="text-sm font-black text-gray-900 uppercase tracking-widest border-b-2 border-primary pb-2 mb-4">Métricas</h3>
          <div class="grid grid-cols-2 gap-3">
            <div class="text-center bg-gray-50 border border-gray-100 p-3 rounded-xl shadow-sm">
              <div class="text-2xl font-black text-primary">{personalInfo.stats.experience}</div>
              <div class="text-[9px] text-gray-500 uppercase font-black tracking-wider leading-tight">{ui.hero.expLabel}</div>
            </div>
            <div class="text-center bg-gray-50 border border-gray-100 p-3 rounded-xl shadow-sm">
              <div class="text-2xl font-black text-primary">{personalInfo.stats.projects}</div>
              <div class="text-[9px] text-gray-500 uppercase font-black tracking-wider leading-tight">{ui.hero.projectsLabel}</div>
            </div>
          </div>
        </section>

        <!-- Services / Skills -->
        <section>
          <h3 class="text-sm font-black text-gray-900 uppercase tracking-widest border-b-2 border-primary pb-2 mb-4">Core Skills</h3>
          <ul class="space-y-4">
            {services.slice(0, 4).map(s => (
              <li>
                <h4 class="font-bold text-[13px] text-gray-900 mb-1.5 leading-tight">{s.title}</h4>
                <div class="flex flex-wrap gap-1">
                  {s.tags.slice(0, 4).map(t => (
                    <span class="text-[9px] border border-gray-200 bg-gray-50 text-gray-700 px-1.5 py-0.5 rounded font-medium">{t}</span>
                  ))}
                </div>
              </li>
            ))}
          </ul>
        </section>

        <!-- Certifications -->
        <section>
          <h3 class="text-sm font-black text-gray-900 uppercase tracking-widest border-b-2 border-primary pb-2 mb-4 mt-2">Certificaciones IAM</h3>
          <ul class="space-y-3">
            {personalInfo.certifications?.slice(0, 5).map(cert => (
              <li class="text-xs flex items-start gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary mt-0.5 shrink-0"><path d="M12 15l-2 5l9-5l-9-5l2 5z"/><circle cx="12" cy="8" r="5"/></svg>
                <div>
                  <span class="font-bold text-gray-800 block text-[11px] leading-tight mb-0.5">{cert.title}</span>
                  <span class="text-[10px] text-gray-500 font-medium">{cert.issuer} • {cert.date}</span>
                </div>
              </li>
            ))}
          </ul>
        </section>

      </div>
    </div>
  </div>
  
  <!-- HOJA 2: CASOS DE ESTUDIO / PORTAFOLIO -->
  <div class="a4-page flex flex-col page-break">
    <header class="bg-[#0a0a0A] p-8">
      <h2 class="text-xl font-black text-white uppercase tracking-widest">Selected <span class="text-primary">Works</span></h2>
      <p class="text-gray-400 text-sm mt-1">Soluciones arquitectónicas y despliegues técnicos recientes.</p>
    </header>
    
    <div class="p-10 flex-1 grid grid-cols-2 gap-8">
      {projects.map(p => (
        <div class="bg-white rounded-2xl overflow-hidden border border-gray-200 flex flex-col shadow-sm">
          <div class="h-40 bg-gray-100 relative overflow-hidden border-b border-gray-100">
            <!-- Project Image Thumbnail -->
            {p.images && p.images.length > 0 && <img src={p.images[0]} alt={p.title} class="object-cover w-full h-full object-top" />}
          </div>
          <div class="p-5 flex-1 flex flex-col">
            <span class="text-[8px] text-primary font-black tracking-widest uppercase mb-1.5">{p.category}</span>
            <h3 class="font-black text-gray-900 text-base mb-2">{p.title}</h3>
            <p class="text-[11px] text-gray-600 mb-4 flex-1 text-justify leading-relaxed">{p.description}</p>
            <div class="flex flex-wrap gap-1.5 mt-auto">
              {p.tech.slice(0, 4).map(t => (
                <span class="text-[9px] bg-gray-50 border border-gray-200 text-gray-700 px-2 py-1 rounded font-semibold">{t}</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
    
    <footer class="mt-auto p-8 text-center text-xs text-gray-500 font-medium bg-gray-50 border-t border-gray-100">
      Portafolio interactivo disponible en <strong class="text-gray-900">yeisonruiz.com</strong> | {new Date().getFullYear()}
    </footer>
  </div>

</body>
</html>
